import json
import os
import socket
import subprocess
from pathlib import Path

import yaml

_host = os.environ.get("REREC_HOST", socket.gethostname()).split(".")[0]
_base = Path(workflow.basedir)
_host_cfg = _base / f"config-{_host}.yaml"
_merged_cfg = _base / ".snakemake" / f"config-{_host}.merged.yaml"
_merged_cfg.parent.mkdir(parents=True, exist_ok=True)

with open(_base / "config.yaml") as _fh:
    _cfg = yaml.safe_load(_fh) or {}
if _host_cfg.is_file():
    with open(_host_cfg) as _fh:
        _cfg.update(yaml.safe_load(_fh) or {})
with open(_merged_cfg, "w") as _fh:
    yaml.dump(_cfg, _fh, default_flow_style=False, sort_keys=False)

configfile: str(_merged_cfg)

_PROD_COMMON = _base / "common"
if not _PROD_COMMON.is_dir():
    _PROD_COMMON = _base.parent / "common"

MU3E_REREC_BASEDIR = config["mu3e_rereco_basedir"]
MU3E_TAG = config.get("mu3e_tag", "master")
MU3E_CHECKOUT_BRANCH = (config.get("mu3e_checkout_branch") or "").strip()
if MU3E_CHECKOUT_BRANCH:
    MU3E_CHECKOUT_REF = ""
else:
    MU3E_CHECKOUT_REF = config.get("mu3e_checkout_tag", MU3E_TAG)

MU3E_CHECKOUT_MERGES = []
_checkout_merge_one = (config.get("mu3e_checkout_merge") or "").strip()
if _checkout_merge_one:
    MU3E_CHECKOUT_MERGES.append(_checkout_merge_one)
for _m in config.get("mu3e_checkout_merges") or []:
    _ms = str(_m).strip()
    if _ms and _ms not in MU3E_CHECKOUT_MERGES:
        MU3E_CHECKOUT_MERGES.append(_ms)

MU3E_UTIL_CHECKOUT_MERGES = []
_util_merge_one = (config.get("mu3eUtil_checkout_merge") or "").strip()
if _util_merge_one:
    MU3E_UTIL_CHECKOUT_MERGES.append(_util_merge_one)
for _m in config.get("mu3eUtil_checkout_merges") or []:
    _ms = str(_m).strip()
    if _ms and _ms not in MU3E_UTIL_CHECKOUT_MERGES:
        MU3E_UTIL_CHECKOUT_MERGES.append(_ms)
MU3E_UTIL_SUBDIR = (config.get("mu3eUtil_subdir") or "modules/mu3eUtil").strip()

MU3E_DIR_BASE = config["mu3e_dir"]
MU3E_TAG_DIRSAFE = MU3E_TAG.replace("/", "_")
MU3E_WORKDIR_NAME = config.get("mu3e_workdir_name")
if MU3E_WORKDIR_NAME:
    SETUP_ROOT_NAME = MU3E_WORKDIR_NAME
else:
    SETUP_ROOT_NAME = f"mu3e-rereco-{MU3E_TAG_DIRSAFE}"
SETUP_ROOT = f"{MU3E_REREC_BASEDIR}/{SETUP_ROOT_NAME}"
MU3E_DIR = f"{SETUP_ROOT}/{MU3E_DIR_BASE}"
workdir: SETUP_ROOT

MU3E_REPO = config["mu3e_repo"]
MAKE_JOBS = config["make_jobs"]
RELINK_SCRIPT = config["relink_script"]
SORT_INPUT_BASE = config.get("sort_input_base", "")
RAW_INPUT_LAYOUT = config.get("raw_input_layout", "flat")

_midas_exe_rel = config.get(
    "midas_meta_exe",
    "modules/mu3eUtil/tools/midasMeta/mu3e_midas_meta",
)

_load_tasks_script = _PROD_COMMON / "load_rereco_tasks"
_proc = subprocess.run(
    ["perl", str(_load_tasks_script), "--base", str(_base)],
    input=json.dumps(dict(config)),
    capture_output=True,
    text=True,
    check=False,
)
if _proc.returncode != 0:
    raise RuntimeError(
        _proc.stderr.strip() or f"load_rereco_tasks failed with exit {_proc.returncode}"
    )
REREC_TASKS = json.loads(_proc.stdout)

TRIREC_OUTPUT_TPL = config.get("trirec_output_tpl", "output/trirec-{task}.root")
MARKER_DIR = (config.get("marker_dir") or "markers").strip().strip("/")
MIDAS_META_MARKER_TPL = config.get("midas_meta_marker_tpl") or f"{MARKER_DIR}/midas_meta-{{task}}.done"

CDB_DBCONN = config.get("cdb_dbconn", config.get("cdb_db_conn"))
CDB_GT = config.get("cdb_GT", config.get("cdb_gt"))

MU3E_WORK_BASEDIR = SETUP_ROOT
MU3E_PREP_LOG_PREFIX = "rereco"
CLONE_MU3E_SCRIPT = str(_PROD_COMMON / "scripts" / "clone_and_prepare_mu3e")
CLONE_MU3E_INPUTS = [f"{MARKER_DIR}/clone_mu3e_deps.done"]
MIDAS_META_PREREQS = [f"{MARKER_DIR}/build_mu3e.done"]
MIDAS_META_SCRIPT = str(_PROD_COMMON / "scripts" / "run_midas_meta_dir")
MIDAS_META_FILE_SCRIPT = str(_PROD_COMMON / "scripts" / "run_midas_meta_file")
MIDAS_META_SUBMIT_SCRIPT = str(_PROD_COMMON / "scripts" / "run_midas_meta_submit")
MIDAS_META_EXE = f"{MU3E_DIR}/_build/{_midas_exe_rel}"

JOB_SUBMIT_MODE = config.get("job_submit_mode", "local")
SLURM_PARTITION = config.get("slurm_partition", "mu3e")
SLURM_MEM = (config.get("slurm_mem") or "").strip()
SLURM_LOG_DIR = (config.get("slurm_log_dir") or "").strip() or f"{SETUP_ROOT}/logs/slurm"
_slurm_batch = (config.get("slurm_batch_script") or "").strip()
if _slurm_batch:
    SLURM_BATCH_SCRIPT = (
        _slurm_batch if os.path.isabs(_slurm_batch) else str((_base / _slurm_batch).resolve())
    )
else:
    SLURM_BATCH_SCRIPT = ""
SETUP_DIR = str(_base)

include: str(_PROD_COMMON / "mu3e_prepare.smk")


if REREC_TASKS:
    TASK_IDS = [item["id"] for item in REREC_TASKS]
    TASK_BY_ID = {item["id"]: item for item in REREC_TASKS}
    TRIREC_TASK_IDS = [item["id"] for item in REREC_TASKS if item["action"] == "trirec"]
    MIDAS_META_TASK_IDS = [item["id"] for item in REREC_TASKS if item["action"] == "midas_meta"]

    def trirec_output(task):
        return TRIREC_OUTPUT_TPL.format(task=task)

    def sort_input_path(task):
        item = TASK_BY_ID[task]
        path = item["sort_input"]
        if os.path.isabs(path):
            return path
        if SORT_INPUT_BASE:
            return f"{SORT_INPUT_BASE}/{path}"
        return path

    def task_run_id(task):
        return TASK_BY_ID[task]["run_id"]

    def trirec_conf(task):
        return TASK_BY_ID[task]["trirec_conf"]

    def trirec_conf_fallback(task):
        return TASK_BY_ID[task].get("trirec_conf_fallback", "")

    def _runblock_dir(run_id, layout):
        block = int(run_id) // 1000
        if layout == "runblock3":
            return f"{block:03d}"
        if layout == "runblock4":
            return f"{block:04d}"
        return ""

    def _runblock_prefix(run_id, layout):
        rb = _runblock_dir(run_id, layout)
        return f"{rb}/" if rb else ""

    def _base_includes_runblock(base, run_id, layout):
        rb = _runblock_dir(run_id, layout)
        if not rb:
            return False
        norm = base.rstrip("/")
        return norm.endswith(f"/{rb}")

    def _resolve_input_path(item, key, base_keys=("input_dir_base",)):
        path = (item.get(key) or "").strip()
        if not path:
            return ""
        if os.path.isabs(path):
            return path
        base = ""
        for bk in base_keys:
            base = (item.get(bk) or "").strip()
            if base:
                break
        if not base:
            base = SORT_INPUT_BASE
        layout = item.get("raw_input_layout", RAW_INPUT_LAYOUT)
        prefix = ""
        run_id = item.get("run_id")
        if run_id is not None and layout in ("runblock3", "runblock4"):
            if not _base_includes_runblock(base, run_id, layout):
                prefix = _runblock_prefix(run_id, layout)
        if base:
            return f"{base}/{prefix}{path}"
        if prefix:
            return f"{prefix}{path}"
        return path

    def midas_meta_input_dir(task):
        return _resolve_input_path(TASK_BY_ID[task], "input_dir")

    def midas_meta_input_file(task):
        return _resolve_input_path(
            TASK_BY_ID[task],
            "input_file",
            base_keys=("input_file_base", "input_dir_base"),
        )

    def midas_meta_marker_path(task):
        return MIDAS_META_MARKER_TPL.format(task=task)

    def midas_meta_task_run_id(task):
        return TASK_BY_ID[task].get("run_id", "")

    def midas_meta_task_label(task):
        return task

    TRIREC_LOG_TPL = "logs/snakemake/run_mu3e_trirec-{task}.log"

    def trirec_rule_inputs(wc):
        return [f"{MARKER_DIR}/relink_bin_files.done", sort_input_path(wc.task)]

    def trirec_sort_input(wc):
        return sort_input_path(wc.task)

    def trirec_output_rel(wc):
        return trirec_output(wc.task)

    def trirec_conf_for(wc):
        return trirec_conf(wc.task)

    def trirec_conf_fallback_for(wc):
        return trirec_conf_fallback(wc.task)

    def trirec_run_id_for(wc):
        return task_run_id(wc.task)

    def trirec_item_label(wc):
        return wc.task

    include: str(_PROD_COMMON / "mu3e_trirec.smk")
    include: str(_PROD_COMMON / "midas_meta.smk")

    wildcard_constraints:
        task="|".join(TASK_IDS),

    ALL_TARGETS = [f"{MU3E_DIR}/run/{trirec_output(task)}" for task in TRIREC_TASK_IDS]
    ALL_TARGETS += [midas_meta_marker_path(task) for task in MIDAS_META_TASK_IDS]

    rule midas_meta_all:
        """Concrete target: all midas_meta markers for the configured run/task list."""
        input:
            [midas_meta_marker_path(task) for task in MIDAS_META_TASK_IDS]

    rule trirec_all:
        """Concrete target: all trirec outputs for the configured run/task list."""
        input:
            [f"{MU3E_DIR}/run/{trirec_output(task)}" for task in TRIREC_TASK_IDS]
else:
    ALL_TARGETS = []

    _NO_TASKS_MSG = (
        "no reprocessing tasks configured; set min_run/max_run or run_list_file "
        "(e.g. snakemake --config min_run=4756 max_run=4756 -- midas_meta_all)"
    )

    rule midas_meta_all:
        run:
            raise ValueError(_NO_TASKS_MSG)

    rule trirec_all:
        run:
            raise ValueError(_NO_TASKS_MSG)


rule mu3e_setup:
    """Clone, build, and relink MU3E; no midas_meta or trirec actions."""
    input:
        f"{MARKER_DIR}/relink_bin_files.done"


rule all:
    input:
        ALL_TARGETS if ALL_TARGETS else [f"{MARKER_DIR}/relink_bin_files.done"]


rule ensure_clone_mu3e_deps:
    output:
        f"{MARKER_DIR}/clone_mu3e_deps.done"
    shell:
        f"mkdir -p {MARKER_DIR} && touch {{output}}"


localrules: clean, ensure_clone_mu3e_deps

rule clean:
    shell:
        r"""
        set -euo pipefail
        rm -f "{MU3E_DIR}/run/output/trirec-"*.root
        rm -f "{SETUP_ROOT}/{MARKER_DIR}/midas_meta-"*.done
        rm -f "{SETUP_ROOT}/{MARKER_DIR}/relink_bin_files.done"
        rm -f "{SETUP_ROOT}/{MARKER_DIR}/build_mu3e.done"
        rm -f "{SETUP_ROOT}/{MARKER_DIR}/clone_and_prepare_mu3e.done"
        rm -f "{SETUP_ROOT}/{MARKER_DIR}/clone_mu3e_deps.done"
        rm -rf "{SETUP_ROOT}/.markers"
        """
