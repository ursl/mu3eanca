configfile: str(_merged_cfg)

_PROD_COMMON = _base / "common"
if not _PROD_COMMON.is_dir():
    _PROD_COMMON = _base.parent / "common"

MU3E_RELVAL_BASEDIR = config["mu3e_relval_basedir"]
MU3E_TAG = config.get("mu3e_tag", "master")
MU3E_CHECKOUT_BRANCH = (config.get("mu3e_checkout_branch") or "").strip()
if MU3E_CHECKOUT_BRANCH:
    MU3E_CHECKOUT_REF = ""
