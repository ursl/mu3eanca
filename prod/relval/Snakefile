# Linux: run as host user so outputs on NFS are owned correctly (mu3edb0).
# macOS/Colima: omit --user; the image default user can write bind mounts only
# under paths Colima shares from the host (not $TMPDIR / /var/folders / /tmp).
_is_darwin = platform.system() == "Darwin"
_user_cfg = config.get("histocompare_docker_user", "auto")
if _user_cfg == "auto":
    HISTOCOMPARE_DOCKER_USER = "" if _is_darwin else '--user "$(id -u):$(id -g)"'
elif _user_cfg in ("none", "root", ""):
    HISTOCOMPARE_DOCKER_USER = ""
else:
    HISTOCOMPARE_DOCKER_USER = '--user "$(id -u):$(id -g)"'

_platform_cfg = config.get("histocompare_docker_platform", "auto")
if _platform_cfg == "auto":
    _arm_mac = _is_darwin and platform.machine().lower() in ("arm64", "aarch64")
    HISTOCOMPARE_DOCKER_PLATFORM = "--platform linux/amd64" if _arm_mac else ""
elif _platform_cfg:
    HISTOCOMPARE_DOCKER_PLATFORM = f"--platform {_platform_cfg}"
else:
    HISTOCOMPARE_DOCKER_PLATFORM = ""

# Colima/Docker Desktop: bind-mount writes to /tmp or $TMPDIR fail; use relval base.
if _is_darwin:
    HISTOCOMPARE_HC_TMP_MKTEMP = f"{MU3E_RELVAL_BASEDIR}/.relval-histocompare.XXXXXX"
else:
    HISTOCOMPARE_HC_TMP_MKTEMP = "${TMPDIR:-/tmp}/relval-histocompare.XXXXXX"


def _fmt_tpl(tpl, task):
    return tpl.format(task=task, scenario=task)


def task_cdb_gt(task):
    return TASK_BY_ID[task]["cdb_GT"]


def task_mode(task):
    return TASK_BY_ID[task]["mode"]


def task_treedump_enabled(task):
    item = TASK_BY_ID[task]
    if "treedump" in item:
        val = item["treedump"]
        if isinstance(val, bool):
            return val
        s = str(val).strip().lower()
        return s not in ("0", "false", "no", "")
    return task_mode(task) == "sim"


TREEDUMP_TASK_IDS = [t for t in TASK_IDS if task_treedump_enabled(t)]
HISTOCOMPARE_TASK_IDS = list(TREEDUMP_TASK_IDS)


def sim_conf(task):
    return TASK_BY_ID[task]["sim_conf"]


def trirec_conf(task):
    return TASK_BY_ID[task]["trirec_conf"]


def trirec_conf_fallback(task):
    return TASK_BY_ID[task].get("trirec_conf_fallback", "")


def sim_output(task):
    return _fmt_tpl(SIM_OUTPUT_TPL, task)


def sort_output(task):
    return _fmt_tpl(SORT_OUTPUT_TPL, task)


def trirec_output(task):
    return _fmt_tpl(TRIREC_OUTPUT_TPL, task)


def _runblock_dir(run_id, layout):
    block = int(run_id) // 1000
    if layout == "runblock3":
        return f"{block:03d}"
    if layout == "runblock4":
        return f"{block:04d}"
    return ""


def raw_input_path(task):
    item = TASK_BY_ID[task]
    path = (item.get("raw_input") or item.get("sort_input") or "").strip()
    if not path:
        raise ValueError(f"raw_input missing for task {task}")
    if os.path.isabs(path):
        return path
    if not RAW_INPUT_BASE:
        return path
    layout = item.get("raw_input_layout", RAW_INPUT_LAYOUT)
    run_id = item["run_id"]
    rb = _runblock_dir(run_id, layout)
    prefix = ""
    if rb and not path.startswith(f"{rb}/"):
        prefix = f"{rb}/"
    return f"{RAW_INPUT_BASE}/{prefix}{path}"


TRIREC_LOG_TPL = "logs/snakemake/run_mu3e_trirec-{task}.log"


def trirec_rule_inputs(wc):
    return [f"{MU3E_DIR}/run/{sort_output(wc.task)}"]


def trirec_sort_input(wc):
    return sort_output(wc.task)


def trirec_output_rel(wc):
    return trirec_output(wc.task)


def trirec_conf_for(wc):
    return trirec_conf(wc.task)


def trirec_conf_fallback_for(wc):
    return trirec_conf_fallback(wc.task)


def trirec_run_id_for(wc):
    return TASK_BY_ID[wc.task]["run_id"]


def trirec_cdb_gt_for(wc):
    return task_cdb_gt(wc.task)


def trirec_item_label(wc):
    return wc.task


include: str(_PROD_COMMON / "mu3e_trirec.smk")


def fillhist_output(task):
    return _fmt_tpl(FILLHIST_OUTPUT_TPL, task)


def compare_marker_output(task):
    return _fmt_tpl(COMPARE_MARKER_TPL, task)


def histocompare_marker_output(task):
    return _fmt_tpl(HISTOCOMPARE_MARKER_TPL, task)


def ref_workdir_name():
    return f"mu3e-{COMPARE_AGAINST_SETUP}"


REF_WORKDIR_NAME = ref_workdir_name()


def compare_other_trirec(task):
    return f"{MU3E_RELVAL_BASEDIR}/{ref_workdir_name()}/run/{trirec_output(task)}"


def compare_other_hist(task):
    return f"{MU3E_RELVAL_BASEDIR}/{ref_workdir_name()}/run/{fillhist_output(task)}"


def compare_dir_name(task):
    this_setup = MU3E_DIRNAME
    other_setup = ref_workdir_name()
    return f"{task}__{this_setup}__vs__{other_setup}"


def compare_dir_rel(task):
    return f"run/output/compare/{compare_dir_name(task)}"


def compare_dir_host(task):
    return f"{MU3E_DIR}/{compare_dir_rel(task)}"


ALIGN_OBJECTS = ["sensors", "fibres", "tiles", "mppcs"]


def treedump_basename(task, align_object):
    return f"treedump-{task}-{align_object}"


def treedump_output(task, align_object):
    return f"output/{treedump_basename(task, align_object)}.root"


def treedump_host_path(task, align_object):
    return f"{MU3E_DIR}/run/{treedump_output(task, align_object)}"


def ref_treedump_host_path(task, align_object):
    return f"{MU3E_RELVAL_BASEDIR}/{ref_workdir_name()}/run/{treedump_output(task, align_object)}"


wildcard_constraints:
    task="|".join(TASK_IDS),
    align_object="|".join(ALIGN_OBJECTS),


ALL_TARGETS = [
    f"{MU3E_DIR}/run/{fillhist_output(task)}"
    for task in TASK_IDS
] + [
    treedump_host_path(task, obj)
    for task in TREEDUMP_TASK_IDS
    for obj in ALIGN_OBJECTS
]
if COMPARE_ENABLED:
    ALL_TARGETS += [
        f"{MU3E_DIR}/run/{compare_marker_output(task)}"
        for task in TASK_IDS
    ]
    ALL_TARGETS += [
        f"{MU3E_DIR}/run/{histocompare_marker_output(task)}"
        for task in HISTOCOMPARE_TASK_IDS
    ]


rule all:
    input:
        ALL_TARGETS


rule mu3e_setup:
    """Clone, build, and relink MU3E; no sim/sort/trirec/compare actions."""
    input:
        f"{MARKER_DIR}/relink_bin_files.done"


rule relval_all:
    """Full relval pipeline for all configured tasks."""
    input:
        ALL_TARGETS


if COMPARE_ENABLED:
    rule compare_all:
        input:
            [f"{MU3E_DIR}/run/{compare_marker_output(task)}" for task in TASK_IDS]

    rule histocompare_all:
        input:
            [
                f"{MU3E_DIR}/run/{histocompare_marker_output(task)}"
                for task in HISTOCOMPARE_TASK_IDS
            ]


rule bootstrap_relval_tools:
    output:
        f"{MU3E_RELVAL_BASEDIR}/bootstrap/mu3e_validation_tools.done"
    log:
        "logs/snakemake/bootstrap_relval_tools.log"
    params:
        relval_basedir=MU3E_RELVAL_BASEDIR,
        util_repo=MU3E_UTIL_REPO,
        validation_repo=MU3E_VALIDATION_REPO,
        jobs=MU3E_VALIDATION_MAKE_JOBS
    shell:
        r"""
        mkdir -p "$(dirname "{log}")"
        exec > >(tee "{log}") 2>&1
        set -euo pipefail
        mkdir -p "{params.relval_basedir}"
        mkdir -p "{params.relval_basedir}/bootstrap"

        if [ ! -d "{params.relval_basedir}/mu3eUtil/.git" ]; then
            git clone "{params.util_repo}" "{params.relval_basedir}/mu3eUtil"
        fi
        mkdir -p "{params.relval_basedir}/mu3eUtil/_build"
        cd "{params.relval_basedir}/mu3eUtil/_build"
        cmake ..
        make -j{params.jobs}

        if [ ! -d "{params.relval_basedir}/mu3eValidation/.git" ]; then
            git clone "{params.validation_repo}" "{params.relval_basedir}/mu3eValidation"
        fi
        mkdir -p "{params.relval_basedir}/mu3eValidation/_build"
        cd "{params.relval_basedir}/mu3eValidation/_build"
        cmake ..
        make -j{params.jobs}

        touch "{output}"
        """


if SIM_TASK_IDS:
    rule run_mu3e_sim:
        input:
            f"{MARKER_DIR}/relink_bin_files.done"
        output:
            f"{MU3E_DIR}/run/{SIM_OUTPUT_TPL}"
        log:
            "logs/snakemake/run_mu3e_sim-{task}.log",
        wildcard_constraints:
            task="|".join(SIM_TASK_IDS),
        params:
            mu3e_dir=MU3E_DIR,
            run_id=lambda wc: TASK_BY_ID[wc.task]["run_id"],
            n_events=lambda wc: TASK_BY_ID[wc.task]["n_events"],
            sim_conf=lambda wc: sim_conf(wc.task),
            sim_output=lambda wc: sim_output(wc.task)
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail
            cd "{params.mu3e_dir}/run"
            ../_build/mu3eSim/mu3eSim \
                --run {params.run_id} \
                -n {params.n_events} \
                --conf "{params.sim_conf}" \
                --output "{params.sim_output}"
            """

    rule run_mu3e_sort:
        input:
            f"{MU3E_DIR}/run/{SIM_OUTPUT_TPL}"
        output:
            f"{MU3E_DIR}/run/{SORT_OUTPUT_TPL}"
        log:
            "logs/snakemake/run_mu3e_sort-{task}.log",
        wildcard_constraints:
            task="|".join(SIM_TASK_IDS),
        params:
            mu3e_dir=MU3E_DIR,
            sim_output=lambda wc: sim_output(wc.task),
            sort_output=lambda wc: sort_output(wc.task),
            run_id=lambda wc: TASK_BY_ID[wc.task]["run_id"],
            cdb_dbconn=CDB_DBCONN,
            cdb_gt=lambda wc: task_cdb_gt(wc.task)
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail;
            cd "{params.mu3e_dir}/run";
            ../_build/mu3eSim/sort/mu3eSort \
            "{params.sim_output}" \
            --output "{params.sort_output}" \
            --run {params.run_id} \
            --cdb.dbconn="{params.cdb_dbconn}" \
            --cdb.globalTag="{params.cdb_gt}"
            """

if DATA_TASK_IDS:
    rule run_mu3e_sort_from_raw:
        input:
            f"{MARKER_DIR}/relink_bin_files.done"
        output:
            f"{MU3E_DIR}/run/{SORT_OUTPUT_TPL}"
        log:
            "logs/snakemake/run_mu3e_sort_from_raw-{task}.log",
        wildcard_constraints:
            task="|".join(DATA_TASK_IDS),
        params:
            mu3e_dir=MU3E_DIR,
            raw_input=lambda wc: raw_input_path(wc.task),
            sort_output=lambda wc: sort_output(wc.task),
            run_id=lambda wc: TASK_BY_ID[wc.task]["run_id"],
            cdb_dbconn=CDB_DBCONN,
            cdb_gt=lambda wc: task_cdb_gt(wc.task)
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail
            if [ ! -f "{params.raw_input}" ]; then
                echo "[relval] ERROR: raw input missing: {params.raw_input}" >&2
                exit 1
            fi
            cd "{params.mu3e_dir}/run"
            ../_build/mu3eSim/sort/mu3eSort \
                "{params.raw_input}" \
                --output "{params.sort_output}" \
                --run {params.run_id} \
                --cdb.dbconn="{params.cdb_dbconn}" \
                --cdb.globalTag="{params.cdb_gt}"
            """

rule run_fill_histograms:
    input:
        f"{MU3E_DIR}/run/{TRIREC_OUTPUT_TPL}"
    output:
        f"{MU3E_DIR}/run/{FILLHIST_OUTPUT_TPL}"
    log:
        "logs/snakemake/run_fill_histograms-{task}.log",
    params:
        exe=RUN_FILL_HISTOGRAMS_EXE,
        annotation=lambda wc: f"mu3e-{MU3E_TAG}_{task_cdb_gt(wc.task)}",
        output_path=lambda wc: f"run/{fillhist_output(wc.task)}"
    shell:
        r"""
        mkdir -p "$(dirname "{log}")"
        exec > >(tee "{log}") 2>&1
        set -euo pipefail
        "{params.exe}" \
            --in "{input}" \
            --ann "{params.annotation}" \
            --out "{params.output_path}"
        """


if TREEDUMP_TASK_IDS:
    def treedump_input(wc):
        return f"{MU3E_DIR}/run/{trirec_output(wc.task)}"


    rule run_treedump:
        input:
            treedump_input
        output:
            f"{MU3E_DIR}/run/output/treedump-{{task}}-{{align_object}}.root",
        log:
            "logs/snakemake/run_treedump-{task}-{align_object}.log",
        wildcard_constraints:
            task="|".join(TREEDUMP_TASK_IDS),
        params:
            treedumper_exe=f"{MU3E_RELVAL_BASEDIR}/mu3eUtil/_build/tools/treedump/mu3eTreeDumper",
            treedump_cfg=f"{MU3E_RELVAL_BASEDIR}/mu3eValidation/scripts/treedump_and_histocompare/config.json",
            dump_prefix=lambda wc: f"run/output/{treedump_basename(wc.task, wc.align_object)}",
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail
            mkdir -p run/output
            "{params.treedumper_exe}" "{params.treedump_cfg}" "{input}" "alignment/{wildcards.align_object}" "{params.dump_prefix}"
            """


if COMPARE_ENABLED:
    rule run_compare_histograms:
        input:
            in1=f"{MU3E_DIR}/run/{FILLHIST_OUTPUT_TPL}",
            in2=lambda wc: compare_other_hist(wc.task)
        output:
            f"{MU3E_DIR}/run/{COMPARE_MARKER_TPL}"
        log:
            "logs/snakemake/run_compare_histograms-{task}.log",
        params:
            exe=RUN_COMPARE_HISTOGRAMS_EXE,
            out_dir=lambda wc: compare_dir_rel(wc.task),
            template_tex=COMPARE_TEMPLATE_TEX
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail
            cp "{params.template_tex}" "./template-relval.tex"
            "{params.exe}" \
                --in1 "{input.in1}" \
                --in2 "{input.in2}" \
                --dir "{params.out_dir}"
            touch "{output}"
            """

if COMPARE_ENABLED and HISTOCOMPARE_TASK_IDS:
    rule run_histocompare:
        input:
            compare_done=f"{MU3E_DIR}/run/{COMPARE_MARKER_TPL}",
            treedumps_current=lambda wc: [
                treedump_host_path(wc.task, obj) for obj in ALIGN_OBJECTS
            ],
            treedumps_reference=lambda wc: [
                ref_treedump_host_path(wc.task, obj) for obj in ALIGN_OBJECTS
            ],
        output:
            f"{MU3E_DIR}/run/{HISTOCOMPARE_MARKER_TPL}"
        log:
            "logs/snakemake/run_histocompare-{task}.log",
        wildcard_constraints:
            task="|".join(HISTOCOMPARE_TASK_IDS),
        params:
            out_dir_host=lambda wc: compare_dir_host(wc.task),
            compare_against=COMPARE_AGAINST_SETUP,
        shell:
            r"""
            mkdir -p "$(dirname "{log}")"
            exec > >(tee "{log}") 2>&1
            set -euo pipefail
            mkdir -p "{params.out_dir_host}"
            align_objects="sensors fibres tiles mppcs"

            if ! {HISTOCOMPARE_DOCKER} info >/dev/null 2>&1; then
                echo "[relval] ERROR: docker is not reachable (histocompare needs Docker)." >&2
                echo "[relval]        Ensure the daemon is running and you can run: {HISTOCOMPARE_DOCKER} info" >&2
                exit 125
            fi

            echo "[relval] run_histocompare task={wildcards.task}"
            echo "[relval]   compare dir: {params.out_dir_host}"
            echo "[relval]   reference setup: {params.compare_against}"

            for obj in $align_objects; do
                dump1_host="{MU3E_DIR}/run/output/treedump-{wildcards.task}-$obj.root"
                dump2_host="{MU3E_RELVAL_BASEDIR}/{REF_WORKDIR_NAME}/run/output/treedump-{wildcards.task}-$obj.root"
                dump1_data_obj="/relval/{MU3E_DIRNAME}/run/output/treedump-{wildcards.task}-$obj.root"
                dump2_data_obj="/relval/{REF_WORKDIR_NAME}/run/output/treedump-{wildcards.task}-$obj.root"
                out_name_obj="histocompare-{wildcards.task}-$obj"
                out_pdf_obj="{params.out_dir_host}/$out_name_obj.pdf"
                out_root_obj="{params.out_dir_host}/$out_name_obj.root"
                out_log_obj="{params.out_dir_host}/$out_name_obj.log"
                docker_log="{params.out_dir_host}/$out_name_obj.docker.log"

                echo "[relval] --- alignment object: $obj ---"
                for f in "$dump1_host" "$dump2_host"; do
                    if [ ! -f "$f" ]; then
                        echo "[relval] ERROR: missing treedump input: $f" >&2
                        exit 1
                    fi
                done
                echo "[relval]   host ref : $dump2_host"
                echo "[relval]   host new : $dump1_host"

                hc_tmp=$(mktemp -d "{HISTOCOMPARE_HC_TMP_MKTEMP}")
                chmod u+rwx "$hc_tmp"
                set +e
                set -o pipefail
                {HISTOCOMPARE_DOCKER} run --rm \
                    {HISTOCOMPARE_DOCKER_PLATFORM} \
                    {HISTOCOMPARE_DOCKER_USER} \
                    -w /tmp \
                    -e CLING_STANDARD_PCH=0 \
                    -v "{MU3E_RELVAL_BASEDIR}:/relval:ro" \
                    -v "$hc_tmp:/workdir" \
                    {HISTOCOMPARE_IMAGE} \
                    "$dump1_data_obj" \
                    "$dump2_data_obj" \
                    --treedump --threshold 0.60 --wasserstein 0.60 --accFailFraction 0.05 \
                    --pdf -o "/workdir/$out_name_obj" --skip=eventWeight --skip=farm_status \
                    --skip=frameID --skip=runID --skip=mc_eventID --skip=mc_weight \
                    --twoDimThreshold 1.0 \
                    2>&1 | tee "$docker_log"
                rc=$?
                set +o pipefail
                set -e
                echo "[relval]   docker exit code: $rc (full log: $docker_log)"

                for dst in "$out_pdf_obj" "$out_root_obj" "$out_log_obj"; do
                    if [ -e "$dst" ] && ! rm -f "$dst" 2>/dev/null; then
                        rm -rf "$hc_tmp"
                        echo "[relval] ERROR: cannot remove stale $(basename "$dst") (wrong owner from an earlier container run?)." >&2
                        echo "[relval]        Fix once: sudo chown -R $(id -un):$(id -gn) \"{params.out_dir_host}\"" >&2
                        exit 1
                    fi
                done
                for ext in pdf root log; do
                    src="$hc_tmp/$out_name_obj.$ext"
                    if [ -f "$src" ]; then
                        cp -f "$src" "{params.out_dir_host}/$out_name_obj.$ext"
                    fi
                done
                rm -rf "$hc_tmp"

                if [ "$rc" -ne 0 ]; then
                    if [ -f "$out_pdf_obj" ] && [ -f "$out_root_obj" ] && [ -f "$out_log_obj" ]; then
                        echo "[relval] WARNING: histocompare($obj) exited with code $rc but produced expected outputs; continuing"
                    else
                        echo "[relval] ERROR: histocompare($obj) failed with code $rc and outputs are incomplete" >&2
                        echo "[relval]        See $docker_log and logs/snakemake/run_histocompare-{wildcards.task}.log" >&2
                        exit "$rc"
                    fi
                fi
            done
            touch "{output}"
            """

localrules: clean

rule clean:
    shell:
        r"""
        set -euo pipefail
        rm -rf "{MARKER_DIR}" .markers
        rm -f "{MU3E_DIR}/run/output/sim-"*.root
        rm -f "{MU3E_DIR}/run/output/sort-"*.root
        rm -f "{MU3E_DIR}/run/output/trirec-"*.root
        rm -f "{MU3E_DIR}/run/output/histograms-"*.root
        rm -f "{MU3E_DIR}/run/output/treedump-"*.root
        rm -f "{MU3E_DIR}/run/output/compare-"*.done
        rm -f "{MU3E_DIR}/run/output/histocompare-"*.done
        rm -rf "{MU3E_DIR}/run/output/compare"
        """
