    _ms = str(_m).strip()
    if _ms and _ms not in MU3E_UTIL_CHECKOUT_MERGES:
        MU3E_UTIL_CHECKOUT_MERGES.append(_ms)
_util_merge_branch = (config.get("mu3eUtil_checkout_merge_branch") or "").strip()
