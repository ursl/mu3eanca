#! /usr/bin/perl

# ----------------------------------------------------------------------
# runRelval
# =========
#
# Perl wrapper for relval Snakemake setup creation and execution.
#
# Usage:
#   ./runRelval [--setup-name NAME] [--host HOST] [snakemake args...] --config mu3e_tag=<tag> [other overrides]
#
# Example:
#   ./runRelval --setup-name relval-v65 -j4 -p --config mu3e_tag=v6.5 cdb_GT=mcidealv6.5
#   ./runRelval --all --dry-run
#
# ----------------------------------------------------------------------

use strict;
use warnings;
use Cwd qw(abs_path getcwd);
use File::Basename qw(dirname);
use File::Copy qw(copy);
use File::Path qw(make_path);
use Sys::Hostname qw(hostname);

# ----------------------------------------------------------------------
sub usage {
    print "Usage: $0 [--setup-name NAME] [--host HOST] [--compare-against-setup NAME] [snakemake args...] --config mu3e_tag=<tag> [other config overrides]\n";
    print "Example: $0 --setup-name relval-v65 -j4 -p --config mu3e_tag=v6.5 cdb_GT=mcidealv6.5\n";
}

# ----------------------------------------------------------------------
sub prefix {
    my ($long) = @_;
    my $now = localtime;
    $long .= "                         ";
    my $shorter = substr($long, 0, 15);
    return $now . "/" . $shorter . "/ ";
}

# ----------------------------------------------------------------------
sub read_yaml_quoted_value {
    my ($path, $key) = @_;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^$key:\s*"(.*)"/) {
            close($fh);
            return $1;
        }
    }
    close($fh);
    return "";
}

# ----------------------------------------------------------------------
sub read_yaml_scalar_value {
    my ($path, $key) = @_;
    return "" unless -f $path;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^$key:\s*"(.*)"/) {
            close($fh);
            return $1;
        }
        if ($line =~ /^$key:\s*(\S+)/) {
            close($fh);
            return $1;
        }
    }
    close($fh);
    return "";
}

# ----------------------------------------------------------------------
sub relval_host {
    my ($cli_host) = @_;
    if (defined $cli_host && $cli_host ne "") {
        return $cli_host;
    }
    if (defined $ENV{RELVAL_HOST} && $ENV{RELVAL_HOST} ne "") {
        return $ENV{RELVAL_HOST};
    }
    my $h = hostname();
    $h =~ s/\..*//;
    return $h;
}

# ----------------------------------------------------------------------
sub host_config_path {
    my ($host) = @_;
    return "config-$host.yaml";
}

# ----------------------------------------------------------------------
sub read_yaml_quoted_overrides {
    my ($path) = @_;
    my %over = ();
    return %over unless -f $path;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^([A-Za-z0-9_]+):\s*"(.*)"/) {
            $over{$1} = $2;
        }
    }
    close($fh);
    return %over;
}

# ----------------------------------------------------------------------
sub read_config_value {
    my ($host, $key) = @_;
    my $hostpath = host_config_path($host);
    if (-f $hostpath) {
        my $v = read_yaml_quoted_value($hostpath, $key);
        return $v if $v ne "";
    }
    return read_yaml_quoted_value("config.yaml", $key);
}

# ----------------------------------------------------------------------
sub merge_config_lines {
    my ($base_path, $host_path) = @_;
    my %over = read_yaml_quoted_overrides($host_path);
    open(my $in, "<", $base_path) or die "Cannot open $base_path: $!\n";
    my @lines = <$in>;
    close($in);

    my @out = ();
    my %seen = ();
    foreach my $line (@lines) {
        if ($line =~ /^([A-Za-z0-9_]+):/) {
            my $key = $1;
            if (exists $over{$key}) {
                push(@out, "$key: \"$over{$key}\"\n");
                $seen{$key} = 1;
                next;
            }
        }
        push(@out, $line);
    }
    foreach my $key (sort keys %over) {
        next if $seen{$key};
        push(@out, "$key: \"$over{$key}\"\n");
    }
    return @out;
}

# ----------------------------------------------------------------------
sub write_lines {
    my ($path, $lines_ref) = @_;
    open(my $out, ">", $path) or die "Cannot write $path: $!\n";
    foreach my $line (@{$lines_ref}) {
        print $out $line;
    }
    close($out);
}

# ----------------------------------------------------------------------
sub run_cmd {
    my (@cmd) = @_;
    print(prefix("runRelval"), "cmd: @cmd\n");
    system(@cmd);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
sub copy_common {
    my ($script_dir, $setup_dir) = @_;
    my $common_src = abs_path("$script_dir/../common");
    my $common_dst = "$setup_dir/common";
    if (!-d $common_src) {
        die "ERROR: missing shared Snakemake common dir: $common_src\n";
    }
    if (-d $common_dst) {
        system("rm", "-rf", $common_dst);
        if ($? != 0) {
            die "Command failed: rm -rf $common_dst\n";
        }
    }
    run_cmd("cp", "-R", $common_src, $common_dst);
}

# ----------------------------------------------------------------------
sub run_cmd_to_file {
    my ($outfile, @cmd) = @_;
    print(prefix("runRelval"), "cmd: @cmd > $outfile\n");
    open(my $out, ">", $outfile) or die "Cannot write $outfile: $!\n";
    my $pid = open(my $ph, "-|");
    if (!defined $pid) {
        close($out);
        die "open pipe failed for command: @cmd\n";
    } elsif ($pid == 0) {
        open(STDOUT, ">&", fileno($out)) or die "dup stdout failed\n";
        open(STDERR, ">&", fileno($out)) or die "dup stderr failed\n";
        exec @cmd or die "exec failed: @cmd\n";
    }
    close($out);
    waitpid($pid, 0);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
# Snakemake (notably Debian/Ubuntu python3-snakemake 6.x): workflow cores
# from "-jN" can end up as a string in workflow.global_resources.  When
# "--summary" / "--detailed-summary" expand jobs, expand_resources does
# min(global_res, res) and crashes if global_res is str and rule threads int.
# Prefer explicit "--cores N", which is parsed as an integer.
sub snakemake_forwarded_args_normalized {
    my (@args) = @_;
    my $has_explicit_cores = 0;
    for (my $i = 0; $i <= $#args; ++$i) {
        # One token (--cores=4) or first of two (--cores 4)
        if ($args[$i] =~ /^--cores/) {
            $has_explicit_cores = 1;
            last;
        }
        if ($args[$i] =~ /^-c\d+$/) {
            $has_explicit_cores = 1;
            last;
        }
        if ($args[$i] eq '-c' && $i < $#args && $args[$i + 1] =~ /^\d+$/) {
            $has_explicit_cores = 1;
            last;
        }
    }
    return @args if $has_explicit_cores;

    my @out;
    for (my $i = 0; $i <= $#args; ++$i) {
        if ($args[$i] =~ /^-j(\d+)$/) {
            push(@out, '--cores', $1);
        } elsif ($args[$i] eq '-j' && $i < $#args && $args[$i + 1] =~ /^\d+$/) {
            push(@out, '--cores', $args[$i + 1]);
            ++$i;
        } else {
            push(@out, $args[$i]);
        }
    }
    return @out;
}

# ----------------------------------------------------------------------
if ($#ARGV < 0) {
    usage();
    exit(1);
}

# ----------------------------------------------------------------------
# -- command line parsing
# ----------------------------------------------------------------------
my $setup_name = "";
my $compare_against_setup = "";
my $cli_host = "";
my @forwarded_args = ();
my $opt_all = 0;
my $opt_dry_run = 0;

for (my $i = 0; $i <= $#ARGV; ++$i) {
    if ($ARGV[$i] eq "--all") {
        $opt_all = 1;
    } elsif ($ARGV[$i] eq "--setup-name") {
        if ($i + 1 > $#ARGV) {
            die "ERROR: --setup-name requires a value\n";
        }
        $setup_name = $ARGV[$i + 1];
        ++$i;
    } elsif ($ARGV[$i] eq "--compare-against-setup") {
        if ($i + 1 > $#ARGV) {
            die "ERROR: --compare-against-setup requires a value\n";
        }
        $compare_against_setup = $ARGV[$i + 1];
        ++$i;
    } elsif ($ARGV[$i] eq "--host") {
        if ($i + 1 > $#ARGV) {
            die "ERROR: --host requires a value (e.g. moor, mu3edb0)\n";
        }
        $cli_host = $ARGV[$i + 1];
        ++$i;
    } elsif ($ARGV[$i] eq "--dry-run") {
        $opt_dry_run = 1;
    } else {
        push(@forwarded_args, $ARGV[$i]);
    }
}

# -- meta mode: launch the standard relval setups
if ($opt_all) {
    if ($opt_dry_run) {
        my $self = abs_path($0);
        print(prefix("runRelval"), "meta mode --all --dry-run\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.7_mcidealv6.5", " --config", " mu3e_tag=v6.8pre0", " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.6_mcidealv6.5", " --config", " mu3e_tag=v6.7", " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.5_mcidealv6.5", " --config", " mu3e_tag=v6.6",     " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.4.4_mcidealv6.5", " --config", " mu3e_tag=v6.5",     " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.3.3_mcidealv6.1", " --config", " mu3e_tag=v6.4.4",   " cdb_GT=mcidealv6.5", " cdb_dbconn=http://mu3edb0/cdb", "\n");
        print($self, " -j4", " -p", " --config", " mu3e_tag=v6.3.3",   " cdb_GT=mcidealv6.1", " cdb_dbconn=http://mu3edb0/cdb", "\n");
        exit(0);
    } else {
        my $self = abs_path($0);
        print(prefix("runRelval"), "meta mode --all\n");
        run_cmd($self, "-j4", "-p", "--config", "mu3e_tag=v6.3.3",   "cdb_GT=mcidealv6.1", "cdb_dbconn=http://mu3edb0/cdb");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.3.3_mcidealv6.1", "--config", "mu3e_tag=v6.4.4",   "cdb_GT=mcidealv6.5", "cdb_dbconn=http://mu3edb0/cdb");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.4.4_mcidealv6.5", "--config", "mu3e_tag=v6.5",     "cdb_GT=mcidealv6.5");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.5_mcidealv6.5", "--config", "mu3e_tag=v6.6",     "cdb_GT=mcidealv6.5");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.6_mcidealv6.5", "--config", "mu3e_tag=v6.7", "cdb_GT=mcidealv6.5");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.7_mcidealv6.5", "--config", "mu3e_tag=v6.8pre0", "cdb_GT=mcidealv6.5");
        exit(0);
    }
}

my $mu3e_tag = "";
my $mu3e_checkout_branch = "";
my $mu3e_checkout_merge = "";
my $raw_cdb_gt = "";
my $raw_cdb_dbconn = "";

foreach my $arg (@forwarded_args) {
    if ($arg =~ /^mu3e_tag=(.*)$/) {
        $mu3e_tag = $1;
    } elsif ($arg =~ /^mu3e_checkout_branch=(.*)$/) {
        $mu3e_checkout_branch = $1;
    } elsif ($arg =~ /^mu3e_checkout_merge=(.*)$/) {
        $mu3e_checkout_merge = $1;
    } elsif ($arg =~ /^cdb_GT=(.*)$/) {
        $raw_cdb_gt = $1;
    } elsif ($arg =~ /^cdb_gt=(.*)$/) {
        $raw_cdb_gt = $1;
    } elsif ($arg =~ /^cdb_dbconn=(.*)$/) {
        $raw_cdb_dbconn = $1;
    } elsif ($arg =~ /^cdb_db_conn=(.*)$/) {
        $raw_cdb_dbconn = $1;
    }
}

if ($mu3e_tag eq "") {
    print "ERROR: missing mu3e_tag in arguments.\n";
    print "Please pass it as Snakemake config, e.g. --config mu3e_tag=v6.5\n";
    exit(1);
}

my $script_dir = abs_path(dirname($0));
chdir($script_dir) or die "Cannot chdir to $script_dir: $!\n";

my $relval_host = relval_host($cli_host);
my $host_cfg = host_config_path($relval_host);
if (-f $host_cfg) {
    print(prefix("runRelval"), "using host config: $host_cfg (host=$relval_host)\n");
} else {
    print(prefix("runRelval"), "warning: no $host_cfg; using config.yaml only (set --host or RELVAL_HOST if paths are wrong)\n");
}

my $base_dir = read_config_value($relval_host, "mu3e_relval_basedir");
my $mu3e_dir_base = read_config_value($relval_host, "mu3e_dir");
if ($base_dir eq "" || $mu3e_dir_base eq "") {
    die "ERROR: could not parse mu3e_relval_basedir/mu3e_dir from config.yaml + $host_cfg\n";
}

if ($raw_cdb_gt eq "") {
    $raw_cdb_gt = read_config_value($relval_host, "cdb_GT");
}
if ($raw_cdb_dbconn eq "") {
    $raw_cdb_dbconn = read_config_value($relval_host, "cdb_dbconn");
}
if ($mu3e_checkout_branch eq "") {
    $mu3e_checkout_branch = read_yaml_scalar_value("config.yaml", "mu3e_checkout_branch");
    my $host_branch = read_yaml_scalar_value($host_cfg, "mu3e_checkout_branch");
    $mu3e_checkout_branch = $host_branch if $host_branch ne "";
}
if ($mu3e_checkout_merge eq "") {
    $mu3e_checkout_merge = read_yaml_scalar_value("config.yaml", "mu3e_checkout_merge");
    my $host_merge = read_yaml_scalar_value($host_cfg, "mu3e_checkout_merge");
    $mu3e_checkout_merge = $host_merge if $host_merge ne "";
}

if ($setup_name eq "") {
    $setup_name = "relval_" . $mu3e_tag;
    $setup_name =~ s/\//_/g;
}

my $setup_safe = $setup_name;
$setup_safe =~ s/\//_/g;
$setup_safe =~ s/ /_/g;

my $setup_dir = "$base_dir/setups/$setup_safe";
make_path($setup_dir);

copy("$script_dir/Snakefile", "$setup_dir/Snakefile") or die "Copy Snakefile failed: $!\n";
copy_common($script_dir, $setup_dir);

my $cfg_path = "$setup_dir/config.yaml";
my @lines = merge_config_lines("$script_dir/config.yaml", "$script_dir/$host_cfg");

my $mu3e_workdir_name = "mu3e-" . $setup_safe;
my $seen_workdir_name = 0;
my $seen_checkout_tag = 0;
my $seen_checkout_branch = 0;
my $seen_checkout_merge = 0;
my $seen_relval_code_basedir = 0;
my @out = ();

foreach my $line (@lines) {
    if ($line =~ /^mu3e_workdir_name:/) {
        push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n");
        $seen_workdir_name = 1;
    } elsif ($line =~ /^mu3e_checkout_tag:/) {
        if ($mu3e_checkout_branch eq "") {
            push(@out, "mu3e_checkout_tag: \"$mu3e_tag\"\n");
        } else {
            push(@out, "mu3e_checkout_tag: \"\"\n");
        }
        $seen_checkout_tag = 1;
    } elsif ($line =~ /^mu3e_checkout_branch:/) {
        push(@out, "mu3e_checkout_branch: \"$mu3e_checkout_branch\"\n");
        $seen_checkout_branch = 1;
    } elsif ($line =~ /^mu3e_checkout_merge:/) {
        if ($mu3e_checkout_merge ne "") {
            push(@out, "mu3e_checkout_merge: \"$mu3e_checkout_merge\"\n");
        } else {
            push(@out, $line);
        }
        $seen_checkout_merge = 1;
    } elsif ($line =~ /^mu3e_tag:/) {
        push(@out, "mu3e_tag: \"$mu3e_tag\"\n");
    } elsif ($line =~ /^cdb_GT:/) {
        push(@out, "cdb_GT: \"$raw_cdb_gt\"\n");
    } elsif ($line =~ /^cdb_dbconn:/) {
        push(@out, "cdb_dbconn: \"$raw_cdb_dbconn\"\n");
    } elsif ($line =~ /^compare_against_setup:/) {
        push(@out, "compare_against_setup: \"$compare_against_setup\"\n");
    } elsif ($line =~ /^relval_code_basedir:/) {
        push(@out, "relval_code_basedir: \"$script_dir\"\n");
        $seen_relval_code_basedir = 1;
    } else {
        push(@out, $line);
    }
}

if (!$seen_workdir_name) {
    push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n");
}
if (!$seen_checkout_tag && $mu3e_checkout_branch eq "") {
    push(@out, "mu3e_checkout_tag: \"$mu3e_tag\"\n");
}
if (!$seen_checkout_branch) {
    push(@out, "mu3e_checkout_branch: \"$mu3e_checkout_branch\"\n");
}
if (!$seen_checkout_merge && $mu3e_checkout_merge ne "") {
    push(@out, "mu3e_checkout_merge: \"$mu3e_checkout_merge\"\n");
}
if (!$seen_relval_code_basedir) {
    push(@out, "relval_code_basedir: \"$script_dir\"\n");
}
write_lines($cfg_path, \@out);

my $workdir = "$base_dir/$mu3e_workdir_name";

chdir($setup_dir) or die "Cannot chdir to $setup_dir: $!\n";
my @snakemake_args = snakemake_forwarded_args_normalized(@forwarded_args);
if ("@snakemake_args" ne "@forwarded_args") {
    print(prefix("runRelval"), "note: replaced -jN with --cores N for Snakemake (avoids --summary crash on some Debian/Ubuntu builds)\n");
}
run_cmd("snakemake", @snakemake_args);

my $status_dir = "$workdir/status";
make_path($status_dir);

run_cmd_to_file("$status_dir/summary.tsv", "snakemake", "--summary", @snakemake_args);
run_cmd_to_file("$status_dir/detailed-summary.tsv", "snakemake", "--detailed-summary", @snakemake_args);

print "Setup directory: $setup_dir\n";
print "Status exported to: $status_dir\n";
