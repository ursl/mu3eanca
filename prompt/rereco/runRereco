#! /usr/bin/perl

# ----------------------------------------------------------------------
# runRereco
# =========
#
# Perl wrapper for rereco Snakemake setup creation and execution.
#
# Usage: ./runRereco -t TAG [options] [snakemake args...] [snakemake targets...]
#
# Options (this script):
#   -s setup-name   name under setups/ and mu3e-<setup-name> workdir
#   -H host         host config file config-<host>.yaml (default: hostname)
#   -m minRun       minimum run number (run-list mode; written to config.yaml)
#   -M maxRun       maximum run number (run-list mode)
#   -t mu3e_tag     MU3E tag / label (required)
#   -g cdb_GT       CDB global tag
#   -b branch       track origin/<branch> instead of tag checkout
#   -h              help
#
# Arguments after options are passed to snakemake, for example:
#   -n              dry run (do not execute rules)
#   -p              print shell commands before running them (snakemake --printshellcmds)
#   -j4             parallel jobs (normalized to snakemake --cores 4)
#   --config k=v    setup overrides (merged into setup config.yaml, not passed to snakemake)
#   midas_meta_all  concrete snakemake target
#   mu3e_setup      clone + build + relink only (no reprocessing actions)
#
# Examples:
#   ./runRereco -s rereco-v67 -j4 -t dev -b dev -g datav6.5=2025V1 mu3e_setup
#   ./runRereco -s rereco-v67 -j1 -p -t dev -b dev -g datav6.5=2025V1 -m 4756 -M 4756 midas_meta_all
#   ./runRereco -n -p -t v6.7 -g datav6.5=2025V1
#
# History  2025/06/16 first shot
#
# ----------------------------------------------------------------------
# Send all questions, wishes and complaints to the
#
# Author    Urs Langenegger <urslangenegger@gmail.com>
# ----------------------------------------------------------------------

use strict;
use warnings;
use Getopt::Std;
use vars qw($opt_s $opt_H $opt_m $opt_M $opt_t $opt_g $opt_b $opt_h);
use Cwd qw(abs_path);
use File::Basename qw(dirname);
use File::Copy qw(copy);
use File::Path qw(make_path);
use Sys::Hostname qw(hostname);

# ----------------------------------------------------------------------
sub usage {
    print "Usage: $0 -t TAG [options] [snakemake args...] [targets...]\n\n";
    print "Options (runRereco):\n";
    print "  -s setup-name   setup / workdir basename (default: derived from tag and GT)\n";
    print "  -H host         use config-<host>.yaml (default: hostname or REREC_HOST)\n";
    print "  -m minRun       minimum run number for run-list filtering\n";
    print "  -M maxRun       maximum run number for run-list filtering\n";
    print "  -t mu3e_tag     MU3E tag / label (required)\n";
    print "  -g cdb_GT       CDB global tag\n";
    print "  -b branch       checkout origin/<branch> instead of a release tag\n";
    print "  -h              this help\n\n";
    print "Remaining arguments go to snakemake. Common snakemake flags:\n";
    print "  -n              dry run\n";
    print "  -p              print shell commands (snakemake --printshellcmds)\n";
    print "  -jN             run N jobs in parallel\n";
    print "  --config k=v    extra config overrides for the Snakefile\n\n";
    print "  mu3e_setup       Snakemake target: clone + build + relink only\n\n";
    print "Example (MU3E checkout/build only, no runs):\n";
    print "  $0 -s rereco-v67 -j4 -t dev -b dev -g datav6.5=2025V1 mu3e_setup\n\n";
    print "Example (single run midas_meta):\n";
    print "  $0 -s rereco-v67 -j1 -p -t dev -b dev -g datav6.5=2025V1 -m 4756 -M 4756 midas_meta_all\n";
}

# ----------------------------------------------------------------------
sub prefix {
    my ($long) = @_;
    my $now = localtime;
    $long .= "                         ";
    my $shorter = substr($long, 0, 15);
    return $now . "/" . $shorter . "/ ";
}

# ----------------------------------------------------------------------
sub read_yaml_quoted_value {
    my ($path, $key) = @_;
    return "" unless -f $path;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^$key:\s*"(.*)"/) {
            close($fh);
            return $1;
        }
    }
    close($fh);
    return "";
}

# ----------------------------------------------------------------------
sub read_yaml_scalar_value {
    my ($path, $key) = @_;
    return "" unless -f $path;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^$key:\s*"(.*)"/) {
            close($fh);
            return $1;
        }
        if ($line =~ /^$key:\s*(\S+)/) {
            close($fh);
            return $1;
        }
    }
    close($fh);
    return "";
}

# ----------------------------------------------------------------------
sub rereco_host {
    my ($cli_host) = @_;
    if (defined $cli_host && $cli_host ne "") {
        return $cli_host;
    }
    if (defined $ENV{REREC_HOST} && $ENV{REREC_HOST} ne "") {
        return $ENV{REREC_HOST};
    }
    my $h = hostname();
    $h =~ s/\..*//;
    return $h;
}

# ----------------------------------------------------------------------
sub host_config_path {
    my ($host) = @_;
    return "config-$host.yaml";
}

# ----------------------------------------------------------------------
sub read_yaml_quoted_overrides {
    my ($path) = @_;
    my %over = ();
    return %over unless -f $path;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^([A-Za-z0-9_]+):\s*"(.*)"/) {
            $over{$1} = $2;
        }
    }
    close($fh);
    return %over;
}

# ----------------------------------------------------------------------
sub read_config_value {
    my ($host, $key) = @_;
    my $hostpath = host_config_path($host);
    if (-f $hostpath) {
        my $v = read_yaml_quoted_value($hostpath, $key);
        return $v if $v ne "";
    }
    return read_yaml_quoted_value("config.yaml", $key);
}

# ----------------------------------------------------------------------
sub merge_config_lines {
    my ($base_path, $host_path) = @_;
    my %over = read_yaml_quoted_overrides($host_path);
    open(my $in, "<", $base_path) or die "Cannot open $base_path: $!\n";
    my @lines = <$in>;
    close($in);

    my @out = ();
    my %seen = ();
    foreach my $line (@lines) {
        if ($line =~ /^([A-Za-z0-9_]+):/) {
            my $key = $1;
            if (exists $over{$key}) {
                push(@out, "$key: \"$over{$key}\"\n");
                $seen{$key} = 1;
                next;
            }
        }
        push(@out, $line);
    }
    foreach my $key (sort keys %over) {
        next if $seen{$key};
        push(@out, "$key: \"$over{$key}\"\n");
    }
    return @out;
}

# ----------------------------------------------------------------------
sub write_lines {
    my ($path, $lines_ref) = @_;
    open(my $out, ">", $path) or die "Cannot write $path: $!\n";
    foreach my $line (@{$lines_ref}) {
        print $out $line;
    }
    close($out);
}

# ----------------------------------------------------------------------
sub apply_config_kv {
    my ($cfg, $kv) = @_;
    return if !defined $kv || $kv eq "";
    if ($kv =~ /^mu3e_tag=(.*)$/) {
        $cfg->{mu3e_tag} = $1 unless defined $cfg->{mu3e_tag} && $cfg->{mu3e_tag} ne "";
    } elsif ($kv =~ /^mu3e_checkout_branch=(.*)$/) {
        $cfg->{mu3e_checkout_branch} = $1;
    } elsif ($kv =~ /^mu3e_checkout_merge=(.*)$/) {
        $cfg->{mu3e_checkout_merge} = $1;
    } elsif ($kv =~ /^cdb_GT=(.*)$/ || $kv =~ /^cdb_gt=(.*)$/) {
        $cfg->{cdb_GT} = $1;
    } elsif ($kv =~ /^cdb_dbconn=(.*)$/ || $kv =~ /^cdb_db_conn=(.*)$/) {
        $cfg->{cdb_dbconn} = $1;
    } elsif ($kv =~ /^min_run=(.*)$/) {
        $cfg->{min_run} = $1;
    } elsif ($kv =~ /^max_run=(.*)$/) {
        $cfg->{max_run} = $1;
    } elsif ($kv =~ /^sort_input_base=(.*)$/) {
        $cfg->{sort_input_base} = $1;
    } elsif ($kv =~ /^raw_input_layout=(.*)$/) {
        $cfg->{raw_input_layout} = $1;
    } elsif ($kv =~ /^run_block_digits=(.*)$/) {
        $cfg->{run_block_digits} = $1;
    } elsif ($kv =~ /^run_list_file=(.*)$/) {
        $cfg->{run_list_file} = $1;
    }
}

# ----------------------------------------------------------------------
sub is_config_kv {
    my ($arg) = @_;
    return defined $arg && $arg =~ /^[A-Za-z0-9_]+=/;
}

# ----------------------------------------------------------------------
# Pull --config / key=value out of snakemake argv (persisted in setup config.yaml).
sub extract_snakemake_config {
    my ($argv_ref, $cfg_ref) = @_;
    my @out = ();
    my $i = 0;
    while ($i <= $#$argv_ref) {
        my $a = $argv_ref->[$i];
        if ($a eq '--config') {
            ++$i;
            while ($i <= $#$argv_ref) {
                my $tok = $argv_ref->[$i];
                if (is_config_kv($tok)) {
                    apply_config_kv($cfg_ref, $tok);
                    ++$i;
                } elsif ($tok =~ /\s/ && $tok =~ /=/) {
                    foreach my $kv (split(/\s+/, $tok)) {
                        apply_config_kv($cfg_ref, $kv) if is_config_kv($kv);
                    }
                    ++$i;
                } else {
                    last;
                }
            }
            next;
        }
        if (is_config_kv($a)) {
            apply_config_kv($cfg_ref, $a);
        } else {
            push(@out, $a);
        }
        ++$i;
    }
    @$argv_ref = @out;
}

# ----------------------------------------------------------------------
sub snakemake_forwarded_args_normalized {
    my (@args) = @_;
    my $has_explicit_cores = 0;
    for (my $i = 0; $i <= $#args; ++$i) {
        if ($args[$i] =~ /^--cores/) {
            $has_explicit_cores = 1;
            last;
        }
        if ($args[$i] =~ /^-c\d+$/) {
            $has_explicit_cores = 1;
            last;
        }
        if ($args[$i] eq '-c' && $i < $#args && $args[$i + 1] =~ /^\d+$/) {
            $has_explicit_cores = 1;
            last;
        }
    }
    return @args if $has_explicit_cores;

    my @out;
    for (my $i = 0; $i <= $#args; ++$i) {
        if ($args[$i] =~ /^-j(\d+)$/) {
            push(@out, '--cores', $1);
        } elsif ($args[$i] eq '-j' && $i < $#args && $args[$i + 1] =~ /^\d+$/) {
            push(@out, '--cores', $args[$i + 1]);
            ++$i;
        } else {
            push(@out, $args[$i]);
        }
    }
    return @out;
}

# ----------------------------------------------------------------------
sub run_cmd {
    my (@cmd) = @_;
    print(prefix("runRereco"), "cmd: @cmd\n");
    system(@cmd);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
sub copy_prompt_common {
    my ($script_dir, $setup_dir) = @_;
    my $common_src = abs_path("$script_dir/../common");
    my $common_dst = "$setup_dir/common";
    if (!-d $common_src) {
        die "ERROR: missing shared Snakemake common dir: $common_src\n";
    }
    if (-d $common_dst) {
        system("rm", "-rf", $common_dst);
        if ($? != 0) {
            die "Command failed: rm -rf $common_dst\n";
        }
    }
    run_cmd("cp", "-R", $common_src, $common_dst);
}

# ----------------------------------------------------------------------
sub run_cmd_to_file {
    my ($outfile, @cmd) = @_;
    print(prefix("runRereco"), "cmd: @cmd > $outfile\n");
    open(my $out, ">", $outfile) or die "Cannot write $outfile: $!\n";
    my $pid = open(my $ph, "-|");
    if (!defined $pid) {
        close($out);
        die "open pipe failed for command: @cmd\n";
    } elsif ($pid == 0) {
        open(STDOUT, ">&", fileno($out)) or die "dup stdout failed\n";
        open(STDERR, ">&", fileno($out)) or die "dup stderr failed\n";
        exec @cmd or die "exec failed: @cmd\n";
    }
    close($out);
    waitpid($pid, 0);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
sub is_snakemake_flag {
    my ($arg) = @_;
    return 1 if $arg =~ /^--(config|cores|dry-run|printshellcmds|quiet|reason|rerun-incomplete|keep-going|force|touch|summary|detailed-summary|help)/;
    return 1 if $arg =~ /^-[nprRqklLKSTFUW]$/;
    return 1 if $arg =~ /^-j\d+$/ || $arg =~ /^-c\d+$/;
    return 0;
}

# ----------------------------------------------------------------------
sub partition_argv {
    my (@argv) = @_;
    my @rereco = ();
    my @snakemake = ();

    for (my $i = 0; $i <= $#argv; ++$i) {
        my $a = $argv[$i];
        if ($a eq '--') {
            push(@snakemake, @argv[($i + 1) .. $#argv]);
            last;
        } elsif ($a =~ /^-[sHmMtgbh]$/) {
            push(@rereco, $a);
            if ($a ne '-h' && $i + 1 <= $#argv && $argv[$i + 1] !~ /^-/) {
                push(@rereco, $argv[++$i]);
            }
        } elsif ($a eq '--config' || $a eq '--cores' || $a eq '-j' || $a eq '-c') {
            push(@snakemake, $a);
            if ($i + 1 <= $#argv && $argv[$i + 1] !~ /^-/) {
                push(@snakemake, $argv[++$i]);
            }
        } elsif (is_snakemake_flag($a) || $a =~ /^--/) {
            push(@snakemake, $a);
        } elsif ($a =~ /^-/) {
            push(@snakemake, $a);
        } else {
            push(@snakemake, $a);
        }
    }
    return (\@rereco, \@snakemake);
}

# ----------------------------------------------------------------------
my @snakemake_argv = ();
if ($#ARGV >= 0) {
    my ($rereco_argv, $snakemake_argv_ref) = partition_argv(@ARGV);
    @ARGV = @{$rereco_argv};
    @snakemake_argv = @{$snakemake_argv_ref};
}

getopts('s:H:m:M:t:g:b:h');

if ($opt_h) {
    usage();
    exit(0);
}

my %cfg = ();
$cfg{mu3e_tag}           = $opt_t           if defined $opt_t;
$cfg{cdb_GT}             = $opt_g           if defined $opt_g;
$cfg{mu3e_checkout_branch} = $opt_b         if defined $opt_b;
$cfg{min_run}            = $opt_m           if defined $opt_m;
$cfg{max_run}            = $opt_M           if defined $opt_M;

extract_snakemake_config(\@snakemake_argv, \%cfg);

if (!defined $cfg{mu3e_tag} || $cfg{mu3e_tag} eq "") {
    usage();
    exit(1);
}

my $script_dir = abs_path(dirname($0));
chdir($script_dir) or die "Cannot chdir to $script_dir: $!\n";

my $rereco_host = rereco_host($opt_H);
my $host_cfg = host_config_path($rereco_host);
if (-f $host_cfg) {
    print(prefix("runRereco"), "using host config: $host_cfg (host=$rereco_host)\n");
} else {
    print(prefix("runRereco"), "warning: no $host_cfg; using config.yaml only (set -H or REREC_HOST if paths are wrong)\n");
}

my $base_dir = read_config_value($rereco_host, "mu3e_rereco_basedir");
my $mu3e_dir_base = read_config_value($rereco_host, "mu3e_dir");
if ($base_dir eq "" || $mu3e_dir_base eq "") {
    die "ERROR: could not parse mu3e_rereco_basedir/mu3e_dir from config.yaml + $host_cfg\n";
}

$cfg{cdb_GT} = read_config_value($rereco_host, "cdb_GT")
    if !defined $cfg{cdb_GT} || $cfg{cdb_GT} eq "";
$cfg{cdb_dbconn} = read_config_value($rereco_host, "cdb_dbconn")
    if !defined $cfg{cdb_dbconn} || $cfg{cdb_dbconn} eq "";
if (!defined $cfg{mu3e_checkout_branch} || $cfg{mu3e_checkout_branch} eq "") {
    $cfg{mu3e_checkout_branch} = read_yaml_scalar_value("config.yaml", "mu3e_checkout_branch");
    my $host_branch = read_yaml_scalar_value($host_cfg, "mu3e_checkout_branch");
    $cfg{mu3e_checkout_branch} = $host_branch if $host_branch ne "";
}
if (!defined $cfg{mu3e_checkout_merge} || $cfg{mu3e_checkout_merge} eq "") {
    $cfg{mu3e_checkout_merge} = read_yaml_scalar_value("config.yaml", "mu3e_checkout_merge");
    my $host_merge = read_yaml_scalar_value($host_cfg, "mu3e_checkout_merge");
    $cfg{mu3e_checkout_merge} = $host_merge if $host_merge ne "";
}

my $setup_name = defined $opt_s ? $opt_s : "";
if ($setup_name eq "") {
    $setup_name = "rereco_" . $mu3e_dir_base . "-" . $cfg{mu3e_tag} . "_" . $cfg{cdb_GT};
}

my $setup_safe = $setup_name;
$setup_safe =~ s/\//_/g;
$setup_safe =~ s/ /_/g;

my $setup_dir = "$base_dir/setups/$setup_safe";
make_path($setup_dir);

copy("$script_dir/Snakefile", "$setup_dir/Snakefile") or die "Copy Snakefile failed: $!\n";
copy_prompt_common($script_dir, $setup_dir);

my $cfg_path = "$setup_dir/config.yaml";
my @lines = merge_config_lines("$script_dir/config.yaml", "$script_dir/$host_cfg");

my $mu3e_workdir_name = "mu3e-" . $setup_safe;
my %seen = ();
my @out = ();

foreach my $line (@lines) {
    if ($line =~ /^mu3e_workdir_name:/) {
        push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n");
        $seen{mu3e_workdir_name} = 1;
    } elsif ($line =~ /^mu3e_checkout_tag:/) {
        if ($cfg{mu3e_checkout_branch} eq "") {
            push(@out, "mu3e_checkout_tag: \"$cfg{mu3e_tag}\"\n");
        } else {
            push(@out, "mu3e_checkout_tag: \"\"\n");
        }
        $seen{mu3e_checkout_tag} = 1;
    } elsif ($line =~ /^mu3e_checkout_branch:/) {
        push(@out, "mu3e_checkout_branch: \"$cfg{mu3e_checkout_branch}\"\n");
        $seen{mu3e_checkout_branch} = 1;
    } elsif ($line =~ /^mu3e_checkout_merge:/) {
        if ($cfg{mu3e_checkout_merge} ne "") {
            push(@out, "mu3e_checkout_merge: \"$cfg{mu3e_checkout_merge}\"\n");
        } else {
            push(@out, $line);
        }
        $seen{mu3e_checkout_merge} = 1;
    } elsif ($line =~ /^mu3e_tag:/) {
        push(@out, "mu3e_tag: \"$cfg{mu3e_tag}\"\n");
        $seen{mu3e_tag} = 1;
    } elsif ($line =~ /^cdb_GT:/) {
        push(@out, "cdb_GT: \"$cfg{cdb_GT}\"\n");
        $seen{cdb_GT} = 1;
    } elsif ($line =~ /^cdb_dbconn:/) {
        push(@out, "cdb_dbconn: \"$cfg{cdb_dbconn}\"\n");
        $seen{cdb_dbconn} = 1;
    } elsif ($line =~ /^min_run:/) {
        if (defined $cfg{min_run} && $cfg{min_run} ne "") {
            push(@out, "min_run: $cfg{min_run}\n");
        } else {
            push(@out, $line);
        }
        $seen{min_run} = 1;
    } elsif ($line =~ /^max_run:/) {
        if (defined $cfg{max_run} && $cfg{max_run} ne "") {
            push(@out, "max_run: $cfg{max_run}\n");
        } else {
            push(@out, $line);
        }
        $seen{max_run} = 1;
    } elsif ($line =~ /^sort_input_base:/) {
        if (defined $cfg{sort_input_base} && $cfg{sort_input_base} ne "") {
            push(@out, "sort_input_base: \"$cfg{sort_input_base}\"\n");
        } else {
            push(@out, $line);
        }
        $seen{sort_input_base} = 1;
    } elsif ($line =~ /^raw_input_layout:/) {
        if (defined $cfg{raw_input_layout} && $cfg{raw_input_layout} ne "") {
            push(@out, "raw_input_layout: \"$cfg{raw_input_layout}\"\n");
        } else {
            push(@out, $line);
        }
        $seen{raw_input_layout} = 1;
    } elsif ($line =~ /^run_block_digits:/) {
        if (defined $cfg{run_block_digits} && $cfg{run_block_digits} ne "") {
            push(@out, "run_block_digits: $cfg{run_block_digits}\n");
        } else {
            push(@out, $line);
        }
        $seen{run_block_digits} = 1;
    } elsif ($line =~ /^run_list_file:/) {
        if (defined $cfg{run_list_file} && $cfg{run_list_file} ne "") {
            push(@out, "run_list_file: \"$cfg{run_list_file}\"\n");
        } else {
            push(@out, $line);
        }
        $seen{run_list_file} = 1;
    } else {
        push(@out, $line);
    }
}

push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n") if !$seen{mu3e_workdir_name};
if (!$seen{mu3e_checkout_tag} && $cfg{mu3e_checkout_branch} eq "") {
    push(@out, "mu3e_checkout_tag: \"$cfg{mu3e_tag}\"\n");
}
push(@out, "mu3e_checkout_branch: \"$cfg{mu3e_checkout_branch}\"\n") if !$seen{mu3e_checkout_branch};
push(@out, "mu3e_checkout_merge: \"$cfg{mu3e_checkout_merge}\"\n")
    if !$seen{mu3e_checkout_merge} && $cfg{mu3e_checkout_merge} ne "";
push(@out, "min_run: $cfg{min_run}\n") if !$seen{min_run} && defined $cfg{min_run} && $cfg{min_run} ne "";
push(@out, "max_run: $cfg{max_run}\n") if !$seen{max_run} && defined $cfg{max_run} && $cfg{max_run} ne "";
push(@out, "sort_input_base: \"$cfg{sort_input_base}\"\n")
    if !$seen{sort_input_base} && defined $cfg{sort_input_base} && $cfg{sort_input_base} ne "";
push(@out, "raw_input_layout: \"$cfg{raw_input_layout}\"\n")
    if !$seen{raw_input_layout} && defined $cfg{raw_input_layout} && $cfg{raw_input_layout} ne "";
push(@out, "run_block_digits: $cfg{run_block_digits}\n")
    if !$seen{run_block_digits} && defined $cfg{run_block_digits} && $cfg{run_block_digits} ne "";
push(@out, "run_list_file: \"$cfg{run_list_file}\"\n")
    if !$seen{run_list_file} && defined $cfg{run_list_file} && $cfg{run_list_file} ne "";
write_lines($cfg_path, \@out);

my $workdir = "$base_dir/$mu3e_workdir_name";

chdir($setup_dir) or die "Cannot chdir to $setup_dir: $!\n";
my @snakemake_args = snakemake_forwarded_args_normalized(@snakemake_argv);
if ("@snakemake_args" ne "@snakemake_argv") {
    print(prefix("runRereco"), "note: replaced -jN with --cores N for Snakemake (avoids --summary crash on some Debian/Ubuntu builds)\n");
}
run_cmd("snakemake", @snakemake_args);

my $status_dir = "$workdir/status";
make_path($status_dir);

run_cmd_to_file("$status_dir/summary.tsv", "snakemake", "--summary", @snakemake_args);
run_cmd_to_file("$status_dir/detailed-summary.tsv", "snakemake", "--detailed-summary", @snakemake_args);

print "Setup directory: $setup_dir\n";
print "Work directory:  $workdir\n";
print "Status exported to: $status_dir\n";
