configfile: f"{workflow.basedir}/config.yaml"

MU3E_RELVAL_BASEDIR = config["mu3e_relval_basedir"]
MU3E_TAG = config.get("mu3e_tag", "master")
MU3E_CHECKOUT_TAG = config.get("mu3e_checkout_tag", MU3E_TAG)
MU3E_DIR_BASE = config["mu3e_dir"]
MU3E_TAG_DIRSAFE = MU3E_TAG.replace("/", "_")
MU3E_WORKDIR_NAME = config.get("mu3e_workdir_name")
if MU3E_WORKDIR_NAME:
    MU3E_DIRNAME = MU3E_WORKDIR_NAME
else:
    MU3E_DIRNAME = f"{MU3E_DIR_BASE}-{MU3E_TAG_DIRSAFE}"
MU3E_DIR = f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIRNAME}"
workdir: MU3E_DIR

MU3E_REPO = config["mu3e_repo"]
MAKE_JOBS = config["make_jobs"]
MU3E_UTIL_REPO = config.get("mu3e_util_repo", "git@bitbucket.org:mu3e/mu3eUtil")
MU3E_VALIDATION_REPO = config.get("mu3e_validation_repo", "git@bitbucket.org:mu3e/mu3eValidation")
MU3E_VALIDATION_MAKE_JOBS = int(config.get("mu3e_validation_make_jobs", 20))

RUN_ID = config["run_id"]
N_EVENTS = config["n_events"]

RELINK_SCRIPT = config["relink_script"]

SIM_SCENARIOS = config["sim_scenarios"]
SCENARIO_IDS = [item["id"] for item in SIM_SCENARIOS]
SCENARIO_BY_ID = {item["id"]: item for item in SIM_SCENARIOS}

SIM_OUTPUT_TPL = config["sim_output_tpl"]

SORT_OUTPUT_TPL = config["sort_output_tpl"]
TRIREC_OUTPUT_TPL = config["trirec_output_tpl"]
FILLHIST_OUTPUT_TPL = config["fillhist_output_tpl"]
COMPARE_MARKER_TPL = config.get("compare_marker_tpl", "output/compare-{scenario}.done")
HISTOCOMPARE_MARKER_TPL = config.get("histocompare_marker_tpl", "output/histocompare-{scenario}.done")
RELVAL_CODE_BASEDIR = config.get("relval_code_basedir", workflow.basedir)
RUN_FILL_HISTOGRAMS_EXE = f"{RELVAL_CODE_BASEDIR}/ana/bin/runFillHistograms"
RUN_COMPARE_HISTOGRAMS_EXE = f"{RELVAL_CODE_BASEDIR}/ana/bin/runCompareHistograms"
COMPARE_TEMPLATE_TEX = f"{RELVAL_CODE_BASEDIR}/ana/template-relval.tex"
COMPARE_AGAINST_SETUP = config.get("compare_against_setup", "")
COMPARE_ENABLED = bool(COMPARE_AGAINST_SETUP and RUN_COMPARE_HISTOGRAMS_EXE)

# Allow CLI override via --config cdb_GT=... (and accept lowercase alias).
CDB_DBCONN = config.get("cdb_dbconn", config.get("cdb_db_conn"))
CDB_GT = config.get("cdb_GT", config.get("cdb_gt"))


def sim_conf(scenario):
    return SCENARIO_BY_ID[scenario]["sim_conf"]


def trirec_conf(scenario):
    return SCENARIO_BY_ID[scenario]["trirec_conf"]


def trirec_conf_fallback(scenario):
    return SCENARIO_BY_ID[scenario].get("trirec_conf_fallback", "")


def sim_output(scenario):
    return SIM_OUTPUT_TPL.format(scenario=scenario)


def sort_output(scenario):
    return SORT_OUTPUT_TPL.format(scenario=scenario)


def trirec_output(scenario):
    return TRIREC_OUTPUT_TPL.format(scenario=scenario)


def fillhist_output(scenario):
    return FILLHIST_OUTPUT_TPL.format(scenario=scenario)


def compare_marker_output(scenario):
    return COMPARE_MARKER_TPL.format(scenario=scenario)


def histocompare_marker_output(scenario):
    return HISTOCOMPARE_MARKER_TPL.format(scenario=scenario)


def compare_other_trirec(scenario):
    return f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/{trirec_output(scenario)}"


def compare_other_hist(scenario):
    return f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/{fillhist_output(scenario)}"


def compare_dir_name(scenario):
    this_setup = MU3E_DIRNAME
    other_setup = f"{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}"
    return f"{scenario}__{this_setup}__vs__{other_setup}"


def compare_dir_rel(scenario):
    return f"run/output/compare/{compare_dir_name(scenario)}"


def compare_dir_host(scenario):
    return f"{MU3E_DIR}/{compare_dir_rel(scenario)}"


def compare_in1_data_path(scenario):
    return f"/data/{MU3E_DIRNAME}/run/{trirec_output(scenario)}"


def compare_in2_data_path(scenario):
    return f"/data/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/{trirec_output(scenario)}"


def treedump_file_name(scenario):
    return f"treedump-{scenario}-sensors.root"


def current_treedump_host_path(scenario):
    return f"{MU3E_DIR}/run/output/{treedump_file_name(scenario)}"


def ref_treedump_host_path(scenario):
    return f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/output/{treedump_file_name(scenario)}"


def current_treedump_container_path(scenario):
    return f"/relval/{MU3E_DIRNAME}/run/output/{treedump_file_name(scenario)}"


def ref_treedump_container_path(scenario):
    return f"/relval/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/output/{treedump_file_name(scenario)}"


wildcard_constraints:
    scenario="|".join(SCENARIO_IDS)


ALL_TARGETS = [
    f"{MU3E_DIR}/run/{fillhist_output(scenario)}"
    for scenario in SCENARIO_IDS
]
if COMPARE_ENABLED:
    ALL_TARGETS += [
        f"{MU3E_DIR}/run/{compare_marker_output(scenario)}"
        for scenario in SCENARIO_IDS
    ]
    ALL_TARGETS += [
        f"{MU3E_DIR}/run/{histocompare_marker_output(scenario)}"
        for scenario in SCENARIO_IDS
    ]


rule all:
    input:
        ALL_TARGETS


rule bootstrap_relval_tools:
    output:
        f"{MU3E_RELVAL_BASEDIR}/.bootstrap/mu3e_validation_tools.done"
    params:
        relval_basedir=MU3E_RELVAL_BASEDIR,
        util_repo=MU3E_UTIL_REPO,
        validation_repo=MU3E_VALIDATION_REPO,
        jobs=MU3E_VALIDATION_MAKE_JOBS
    shell:
        r"""
        set -euo pipefail
        mkdir -p "{params.relval_basedir}"
        mkdir -p "{params.relval_basedir}/.bootstrap"

        if [ ! -d "{params.relval_basedir}/mu3eUtil/.git" ]; then
            git clone "{params.util_repo}" "{params.relval_basedir}/mu3eUtil"
        fi
        mkdir -p "{params.relval_basedir}/mu3eUtil/_build"
        cd "{params.relval_basedir}/mu3eUtil/_build"
        cmake ..
        make -j{params.jobs}

        if [ ! -d "{params.relval_basedir}/mu3eValidation/.git" ]; then
            git clone "{params.validation_repo}" "{params.relval_basedir}/mu3eValidation"
        fi
        mkdir -p "{params.relval_basedir}/mu3eValidation/_build"
        cd "{params.relval_basedir}/mu3eValidation/_build"
        cmake ..
        make -j{params.jobs}

        touch "{output}"
        """


rule clone_and_prepare_mu3e:
    input:
        f"{MU3E_RELVAL_BASEDIR}/.bootstrap/mu3e_validation_tools.done"
    output:
        ".markers/clone_and_prepare_mu3e.done"
    params:
        repo=MU3E_REPO,
        tag=MU3E_CHECKOUT_TAG,
        relval_basedir=MU3E_RELVAL_BASEDIR,
        mu3e_dir=MU3E_DIR
    shell:
        r"""
        set -euo pipefail
        mkdir -p .markers
        mkdir -p "{params.relval_basedir}"

        if [ ! -d "{params.mu3e_dir}/.git" ]; then
            # workdir is MU3E_DIR, so it may already contain .snakemake/.markers.
            # If directory is empty, clone normally; otherwise initialize in-place.
            if [ -z "$(ls -A "{params.mu3e_dir}")" ]; then
                git clone "{params.repo}" "{params.mu3e_dir}"
            else
                git -C "{params.mu3e_dir}" init
                if ! git -C "{params.mu3e_dir}" remote get-url origin >/dev/null 2>&1; then
                    git -C "{params.mu3e_dir}" remote add origin "{params.repo}"
                fi
            fi
        fi

        cd "{params.mu3e_dir}"
        git fetch --force origin
        git fetch --tags --force origin
        git checkout "{params.tag}"
        git submodule update --init --recursive

        touch "{output}"
        """


rule build_mu3e:
    input:
        ".markers/clone_and_prepare_mu3e.done"
    output:
        ".markers/build_mu3e.done"
    params:
        mu3e_dir=MU3E_DIR,
        marker_path=f"{MU3E_DIR}/.markers/build_mu3e.done",
        jobs=MAKE_JOBS
    shell:
        r"""
        set -euo pipefail
        mkdir -p "{params.mu3e_dir}/_build"
        cd "{params.mu3e_dir}/_build"
        cmake ..
        make -j{params.jobs}
        touch "{params.marker_path}"
        """


rule relink_bin_files:
    input:
        ".markers/build_mu3e.done"
    output:
        ".markers/relink_bin_files.done"
    params:
        mu3e_dir=MU3E_DIR,
        marker_path=f"{MU3E_DIR}/.markers/relink_bin_files.done",
        relink_script=RELINK_SCRIPT
    shell:
        r"""
        set -euo pipefail
        cd "{params.mu3e_dir}/run"
        "{params.relink_script}"
        if [ ! -d "bvr2026" ]; then
            echo "[relval] run/bvr2026 missing; fetching from bitbucket v6.5"
            tmpdir="$(mktemp -d)"
            git clone --depth 1 --branch v6.5 https://bitbucket.org/mu3e/mu3e "$tmpdir/mu3e-v6.5"
            if [ ! -d "$tmpdir/mu3e-v6.5/run/bvr2026" ]; then
                echo "[relval] ERROR: fetched repo does not contain run/bvr2026" >&2
                rm -rf "$tmpdir"
                exit 1
            fi
            cp -R "$tmpdir/mu3e-v6.5/run/bvr2026" "./bvr2026"
            rm -rf "$tmpdir"
        fi
        mkdir -p output

        touch "{params.marker_path}"
        """


rule run_mu3e_sim:
    input:
        ".markers/relink_bin_files.done"
    output:
        f"{MU3E_DIR}/run/{SIM_OUTPUT_TPL}"
    params:
        mu3e_dir=MU3E_DIR,
        run_id=RUN_ID,
        n_events=N_EVENTS,
        sim_conf=lambda wildcards: sim_conf(wildcards.scenario),
        sim_output=lambda wildcards: sim_output(wildcards.scenario)
    shell:
        r"""
        set -euo pipefail
        cd "{params.mu3e_dir}/run"
        ../_build/mu3eSim/mu3eSim \
            --run {params.run_id} \
            -n {params.n_events} \
            --conf "{params.sim_conf}" \
            --output "{params.sim_output}"
        """

rule run_mu3e_sort:
    input:
        f"{MU3E_DIR}/run/{SIM_OUTPUT_TPL}"
    output:
        f"{MU3E_DIR}/run/{SORT_OUTPUT_TPL}"
    params:
        mu3e_dir=MU3E_DIR,
        sim_output=lambda wildcards: sim_output(wildcards.scenario),
        sort_output=lambda wildcards: sort_output(wildcards.scenario),
        run_id=RUN_ID,
        cdb_dbconn=CDB_DBCONN,
        cdb_GT=CDB_GT
    shell:
        r"""
        set -euo pipefail;
        cd "{params.mu3e_dir}/run";
        ../_build/mu3eSim/sort/mu3eSort \
        "{params.sim_output}" \
        --output "{params.sort_output}" \
        --run {params.run_id} \
        --cdb.dbconn="{params.cdb_dbconn}" \
        --cdb.globalTag="{params.cdb_GT}"
        """

rule run_mu3e_trirec:
    input:
        f"{MU3E_DIR}/run/{SORT_OUTPUT_TPL}"
    output:
        f"{MU3E_DIR}/run/{TRIREC_OUTPUT_TPL}"
    params:
        mu3e_dir=MU3E_DIR,
        sort_output=lambda wildcards: sort_output(wildcards.scenario),
        trirec_output=lambda wildcards: trirec_output(wildcards.scenario),
        trirec_conf=lambda wildcards: trirec_conf(wildcards.scenario),
        trirec_conf_fallback=lambda wildcards: trirec_conf_fallback(wildcards.scenario),
        run_id=RUN_ID,
        cdb_dbconn=CDB_DBCONN,
        cdb_GT=CDB_GT
    shell:
        r"""
        set -euo pipefail;
        cd "{params.mu3e_dir}/run";
        trirec_conf="{params.trirec_conf}";
        if [ ! -f "$trirec_conf" ]; then
            if [ -n "{params.trirec_conf_fallback}" ] && [ -f "{params.trirec_conf_fallback}" ]; then
                echo "[relval] trirec conf '$trirec_conf' missing, using fallback '{params.trirec_conf_fallback}'";
                trirec_conf="{params.trirec_conf_fallback}";
            else
                echo "[relval] ERROR: trirec conf '$trirec_conf' not found and no valid fallback configured" >&2;
                exit 1;
            fi
        fi
        ../_build/mu3eTrirec/mu3eTriRec \
        "{params.sort_output}" \
        --conf "$trirec_conf" \
        --output "{params.trirec_output}" \
        --run {params.run_id} \
        --cdb.dbconn="{params.cdb_dbconn}" \
        --cdb.globalTag="{params.cdb_GT}"
        """


rule run_fill_histograms:
    input:
        f"{MU3E_DIR}/run/{TRIREC_OUTPUT_TPL}"
    output:
        f"{MU3E_DIR}/run/{FILLHIST_OUTPUT_TPL}"
    params:
        exe=RUN_FILL_HISTOGRAMS_EXE,
        annotation=f"mu3e-{MU3E_TAG}_{CDB_GT}",
        output_path=lambda wildcards: f"run/{fillhist_output(wildcards.scenario)}"
    shell:
        r"""
        set -euo pipefail
        "{params.exe}" \
            --in "{input}" \
            --ann "{params.annotation}" \
            --out "{params.output_path}"
        """


if COMPARE_ENABLED:
    rule run_compare_histograms:
        input:
            in1=f"{MU3E_DIR}/run/{FILLHIST_OUTPUT_TPL}",
            in2=lambda wildcards: compare_other_hist(wildcards.scenario)
        output:
            f"{MU3E_DIR}/run/{COMPARE_MARKER_TPL}"
        params:
            exe=RUN_COMPARE_HISTOGRAMS_EXE,
            out_dir=lambda wildcards: compare_dir_rel(wildcards.scenario),
            template_tex=COMPARE_TEMPLATE_TEX
        shell:
            r"""
            set -euo pipefail
            cp "{params.template_tex}" "./template-relval.tex"
            "{params.exe}" \
                --in1 "{input.in1}" \
                --in2 "{input.in2}" \
                --dir "{params.out_dir}"
            touch "{output}"
            """

    rule run_histocompare:
        input:
            compare_done=f"{MU3E_DIR}/run/{COMPARE_MARKER_TPL}",
            sort1=f"{MU3E_DIR}/run/{SORT_OUTPUT_TPL}",
            sort2=lambda wildcards: f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/{SORT_OUTPUT_TPL.format(scenario=wildcards.scenario)}"
        output:
            f"{MU3E_DIR}/run/{HISTOCOMPARE_MARKER_TPL}"
        params:
            out_dir_host=lambda wildcards: compare_dir_host(wildcards.scenario),
            treedumper_exe=f"{MU3E_RELVAL_BASEDIR}/mu3eUtil/_build/tools/treedump/mu3eTreeDumper",
            treedump_cfg=f"{MU3E_RELVAL_BASEDIR}/mu3eValidation/scripts/treedump_and_histocompare/config.json",
            dump1_host_dir=f"{MU3E_DIR}/run/output",
            dump2_host_dir=lambda wildcards: f"{MU3E_RELVAL_BASEDIR}/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/output",
            dump1_data_dir=lambda wildcards: f"/relval/{MU3E_DIRNAME}/run/output",
            dump2_data_dir=lambda wildcards: f"/relval/{MU3E_DIR_BASE}-{COMPARE_AGAINST_SETUP}/run/output"
        shell:
            r"""
            set -euo pipefail
            mkdir -p "{params.out_dir_host}"
            mkdir -p "{params.dump1_host_dir}"
            mkdir -p "{params.dump2_host_dir}"
            align_objects="sensors fibres tiles mppcs"

            for obj in $align_objects; do
                dump_base="treedump-{wildcards.scenario}-$obj"
                dump1_prefix_obj="{params.dump1_host_dir}/$dump_base"
                dump2_prefix_obj="{params.dump2_host_dir}/$dump_base"
                dump1_data_obj="{params.dump1_data_dir}/$dump_base.root"
                dump2_data_obj="{params.dump2_data_dir}/$dump_base.root"
                out_name_obj="histocompare-{wildcards.scenario}-$obj"
                out_pdf_obj="{params.out_dir_host}/$out_name_obj.pdf"
                out_root_obj="{params.out_dir_host}/$out_name_obj.root"
                out_log_obj="{params.out_dir_host}/$out_name_obj.log"

                "{params.treedumper_exe}" "{params.treedump_cfg}" "{input.sort1}" "alignment/$obj" "$dump1_prefix_obj"
                "{params.treedumper_exe}" "{params.treedump_cfg}" "{input.sort2}" "alignment/$obj" "$dump2_prefix_obj"

                cd "{MU3E_RELVAL_BASEDIR}/mu3eValidation"
                set +e
                podman run --rm \
                    -v "{MU3E_RELVAL_BASEDIR}:/relval:ro" \
                    -v "{params.out_dir_host}:/workdir" \
                    docker.io/mu3e/histocompare \
                    "$dump1_data_obj" \
                    "$dump2_data_obj" \
                    --treedump --threshold 0.60 --wasserstein 0.60 --accFailFraction 0.05 \
                    --pdf -o "$out_name_obj" --skip=eventWeight --skip=farm_status \
                    --skip=frameID --skip=runID --skip=mc_eventID --skip=mc_weight \
                    --twoDimThreshold 1.0
                rc=$?
                set -e

                if [ "$rc" -ne 0 ]; then
                    # On some host/container combinations histocompare can segfault
                    # during shutdown although output files are already written.
                    if [ -f "$out_pdf_obj" ] && [ -f "$out_root_obj" ] && [ -f "$out_log_obj" ]; then
                        echo "[relval] WARNING: histocompare($obj) exited with code $rc but produced expected outputs; continuing"
                    else
                        echo "[relval] ERROR: histocompare($obj) failed with code $rc and outputs are incomplete" >&2
                        exit "$rc"
                    fi
                fi
            done
            touch "{output}"
            """

localrules: clean

rule clean:
    shell:
        r"""
        set -euo pipefail
        rm -rf .markers
        rm -f "{MU3E_DIR}/run/output/sim-"*.root
        rm -f "{MU3E_DIR}/run/output/sort-"*.root
        rm -f "{MU3E_DIR}/run/output/trirec-"*.root
        rm -f "{MU3E_DIR}/run/output/histograms-"*.root
        rm -f "{MU3E_DIR}/run/output/treedump-"*.root
        rm -f "{MU3E_DIR}/run/output/compare-"*.done
        rm -f "{MU3E_DIR}/run/output/histocompare-"*.done
        rm -rf "{MU3E_DIR}/run/output/compare"
        """
