#! /usr/bin/perl

# ----------------------------------------------------------------------
# runRelval
# =========
#
# Perl wrapper for relval Snakemake setup creation and execution.
#
# Usage:
#   ./runRelval [--setup-name NAME] [snakemake args...] --config mu3e_tag=<tag> [other overrides]
#
# Example:
#   ./runRelval --setup-name relval-v65 -j4 -p --config mu3e_tag=v6.5 cdb_GT=mcidealv6.5
#   ./runRelval --all --dry-run
#
# ----------------------------------------------------------------------

use strict;
use warnings;
use Cwd qw(abs_path getcwd);
use File::Basename qw(dirname);
use File::Copy qw(copy);
use File::Path qw(make_path);

# ----------------------------------------------------------------------
sub usage {
    print "Usage: $0 [--setup-name NAME] [--compare-against-setup NAME] [snakemake args...] --config mu3e_tag=<tag> [other config overrides]\n";
    print "Example: $0 --setup-name relval-v65 -j4 -p --config mu3e_tag=v6.5 cdb_GT=mcidealv6.5\n";
}

# ----------------------------------------------------------------------
sub prefix {
    my ($long) = @_;
    my $now = localtime;
    $long .= "                         ";
    my $shorter = substr($long, 0, 15);
    return $now . "/" . $shorter . "/ ";
}

# ----------------------------------------------------------------------
sub read_yaml_quoted_value {
    my ($path, $key) = @_;
    open(my $fh, "<", $path) or die "Cannot open $path: $!\n";
    while (my $line = <$fh>) {
        if ($line =~ /^$key:\s*"(.*)"/) {
            close($fh);
            return $1;
        }
    }
    close($fh);
    return "";
}

# ----------------------------------------------------------------------
sub write_lines {
    my ($path, $lines_ref) = @_;
    open(my $out, ">", $path) or die "Cannot write $path: $!\n";
    foreach my $line (@{$lines_ref}) {
        print $out $line;
    }
    close($out);
}

# ----------------------------------------------------------------------
sub run_cmd {
    my (@cmd) = @_;
    print(prefix("runRelval"), "cmd: @cmd\n");
    system(@cmd);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
sub run_cmd_to_file {
    my ($outfile, @cmd) = @_;
    print(prefix("runRelval"), "cmd: @cmd > $outfile\n");
    open(my $out, ">", $outfile) or die "Cannot write $outfile: $!\n";
    my $pid = open(my $ph, "-|");
    if (!defined $pid) {
        close($out);
        die "open pipe failed for command: @cmd\n";
    } elsif ($pid == 0) {
        open(STDOUT, ">&", fileno($out)) or die "dup stdout failed\n";
        open(STDERR, ">&", fileno($out)) or die "dup stderr failed\n";
        exec @cmd or die "exec failed: @cmd\n";
    }
    close($out);
    waitpid($pid, 0);
    if ($? != 0) {
        die "Command failed: @cmd\n";
    }
}

# ----------------------------------------------------------------------
if ($#ARGV < 0) {
    usage();
    exit(1);
}

# ----------------------------------------------------------------------
# -- command line parsing
# ----------------------------------------------------------------------
my $setup_name = "";
my $compare_against_setup = "";
my @forwarded_args = ();
my $opt_all = 0;
my $opt_dry_run = 0;

for (my $i = 0; $i <= $#ARGV; ++$i) {
    if ($ARGV[$i] eq "--all") {
        $opt_all = 1;
    } elsif ($ARGV[$i] eq "--setup-name") {
        if ($i + 1 > $#ARGV) {
            die "ERROR: --setup-name requires a value\n";
        }
        $setup_name = $ARGV[$i + 1];
        ++$i;
    } elsif ($ARGV[$i] eq "--compare-against-setup") {
        if ($i + 1 > $#ARGV) {
            die "ERROR: --compare-against-setup requires a value\n";
        }
        $compare_against_setup = $ARGV[$i + 1];
        ++$i;
    } elsif ($ARGV[$i] eq "--dry-run") {
        $opt_dry_run = 1;
    } else {
        push(@forwarded_args, $ARGV[$i]);
    }
}

# -- meta mode: launch the standard three relval setups
if ($opt_all) {
    if ($opt_dry_run) {
        my $self = abs_path($0);
        print(prefix("runRelval"), "meta mode --all --dry-run\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.6_mcidealv6.5", " --config", " mu3e_tag=v6.7pre0", " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.5_mcidealv6.5", " --config", " mu3e_tag=v6.6",     " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.4.4_mcidealv6.5", " --config", " mu3e_tag=v6.5",     " cdb_GT=mcidealv6.5", "\n");
        print($self, " -j4", " -p", " --compare-against-setup", " relval_mu3e-v6.3.3_datav6.3=2025V1", " --config", " mu3e_tag=v6.4.4",   " cdb_GT=mcidealv6.5", " cdb_dbconn=http://mu3edb0/cdb", "\n");
        print($self, " -j4", " -p", " --config", " mu3e_tag=v6.3.3",   " cdb_GT=datav6.3=2025V1", " cdb_dbconn=http://mu3edb0/cdb", "\n");
        exit(0);
    } else {
        my $self = abs_path($0);
        print(prefix("runRelval"), "meta mode --all\n");
        run_cmd($self, "-j4", "-p", "--config", "mu3e_tag=v6.3.3",   "cdb_GT=datav6.3=2025V1", "cdb_dbconn=http://mu3edb0/cdb");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.3.3_datav6.3=2025V1", "--config", "mu3e_tag=v6.4.4",   "cdb_GT=mcidealv6.5", "cdb_dbconn=http://mu3edb0/cdb");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.4.4_mcidealv6.5", "--config", "mu3e_tag=v6.5",     "cdb_GT=mcidealv6.5");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.5_mcidealv6.5", "--config", "mu3e_tag=v6.6",     "cdb_GT=mcidealv6.5");
        run_cmd($self, "-j4", "-p", "--compare-against-setup", "relval_mu3e-v6.6_mcidealv6.5", "--config", "mu3e_tag=v6.7pre0", "cdb_GT=mcidealv6.5");
        exit(0);
    }
}

my $mu3e_tag = "";
my $raw_cdb_gt = "";
my $raw_cdb_dbconn = "";

foreach my $arg (@forwarded_args) {
    if ($arg =~ /^mu3e_tag=(.*)$/) {
        $mu3e_tag = $1;
    } elsif ($arg =~ /^cdb_GT=(.*)$/) {
        $raw_cdb_gt = $1;
    } elsif ($arg =~ /^cdb_gt=(.*)$/) {
        $raw_cdb_gt = $1;
    } elsif ($arg =~ /^cdb_dbconn=(.*)$/) {
        $raw_cdb_dbconn = $1;
    } elsif ($arg =~ /^cdb_db_conn=(.*)$/) {
        $raw_cdb_dbconn = $1;
    }
}

if ($mu3e_tag eq "") {
    print "ERROR: missing mu3e_tag in arguments.\n";
    print "Please pass it as Snakemake config, e.g. --config mu3e_tag=v6.5\n";
    exit(1);
}

my $script_dir = abs_path(dirname($0));
chdir($script_dir) or die "Cannot chdir to $script_dir: $!\n";

my $base_dir = read_yaml_quoted_value("config.yaml", "mu3e_relval_basedir");
my $mu3e_dir_base = read_yaml_quoted_value("config.yaml", "mu3e_dir");
if ($base_dir eq "" || $mu3e_dir_base eq "") {
    die "ERROR: could not parse mu3e_relval_basedir/mu3e_dir from config.yaml\n";
}

if ($raw_cdb_gt eq "") {
    $raw_cdb_gt = read_yaml_quoted_value("config.yaml", "cdb_GT");
}
if ($raw_cdb_dbconn eq "") {
    $raw_cdb_dbconn = read_yaml_quoted_value("config.yaml", "cdb_dbconn");
}

if ($setup_name eq "") {
    $setup_name = "relval_" . $mu3e_dir_base . "-" . $mu3e_tag . "_" . $raw_cdb_gt;
}

my $setup_safe = $setup_name;
$setup_safe =~ s/\//_/g;
$setup_safe =~ s/ /_/g;

my $setup_dir = "$base_dir/setups/$setup_safe";
make_path($setup_dir);

copy("$script_dir/Snakefile", "$setup_dir/Snakefile") or die "Copy Snakefile failed: $!\n";
copy("$script_dir/config.yaml", "$setup_dir/config.yaml") or die "Copy config.yaml failed: $!\n";

my $cfg_path = "$setup_dir/config.yaml";
open(my $in, "<", $cfg_path) or die "Cannot open $cfg_path: $!\n";
my @lines = <$in>;
close($in);

my $mu3e_workdir_name = $mu3e_dir_base . "-" . $setup_safe;
my $seen_workdir_name = 0;
my $seen_checkout_tag = 0;
my $seen_relval_code_basedir = 0;
my @out = ();

foreach my $line (@lines) {
    if ($line =~ /^mu3e_workdir_name:/) {
        push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n");
        $seen_workdir_name = 1;
    } elsif ($line =~ /^mu3e_checkout_tag:/) {
        push(@out, "mu3e_checkout_tag: \"$mu3e_tag\"\n");
        $seen_checkout_tag = 1;
    } elsif ($line =~ /^mu3e_tag:/) {
        push(@out, "mu3e_tag: \"$mu3e_tag\"\n");
    } elsif ($line =~ /^cdb_GT:/) {
        push(@out, "cdb_GT: \"$raw_cdb_gt\"\n");
    } elsif ($line =~ /^cdb_dbconn:/) {
        push(@out, "cdb_dbconn: \"$raw_cdb_dbconn\"\n");
    } elsif ($line =~ /^compare_against_setup:/) {
        push(@out, "compare_against_setup: \"$compare_against_setup\"\n");
    } elsif ($line =~ /^relval_code_basedir:/) {
        push(@out, "relval_code_basedir: \"$script_dir\"\n");
        $seen_relval_code_basedir = 1;
    } else {
        push(@out, $line);
    }
}

if (!$seen_workdir_name) {
    push(@out, "mu3e_workdir_name: \"$mu3e_workdir_name\"\n");
}
if (!$seen_checkout_tag) {
    push(@out, "mu3e_checkout_tag: \"$mu3e_tag\"\n");
}
if (!$seen_relval_code_basedir) {
    push(@out, "relval_code_basedir: \"$script_dir\"\n");
}
write_lines($cfg_path, \@out);

my $workdir = "$base_dir/$mu3e_dir_base-$setup_safe";

chdir($setup_dir) or die "Cannot chdir to $setup_dir: $!\n";
run_cmd("snakemake", @forwarded_args);

my $status_dir = "$workdir/status";
make_path($status_dir);

run_cmd_to_file("$status_dir/summary.tsv", "snakemake", "--summary", @forwarded_args);
run_cmd_to_file("$status_dir/detailed-summary.tsv", "snakemake", "--detailed-summary", @forwarded_args);

print "Setup directory: $setup_dir\n";
print "Status exported to: $status_dir\n";
